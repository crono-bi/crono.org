---
const products = [
  {
    name: 'Crono Analysis',
    tagline: 'Business Intelligence',
    desc: 'Análisis libre, dashboards e informes predefinidos para toda la organización.',
    href: '/analysis/',
    img: '/analysis.webp',
    color: 'var(--crono-analysis-color)',
    badge: 'Análisis & Reporting',
    svgPath: '<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>',
  },
  {
    name: 'Crono Metadata',
    tagline: 'Capa Semántica',
    desc: 'Crea el catálogo que traduce tu base de datos al lenguaje de negocio.',
    href: '/metadata/',
    img: '/metadata.webp',
    color: 'var(--crono-metadata-color)',
    badge: 'Catálogo & Semántica',
    svgPath: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    name: 'Crono ETL',
    tagline: 'Data Warehouse',
    desc: 'Herramienta ETL diseñada para proyectos de carga de Data Warehouse.',
    href: '/etl/',
    img: '/etl.webp',
    color: 'var(--crono-etl-color)',
    badge: 'ETL & Integración',
    svgPath: '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
  },
  {
    name: 'Crono SQL',
    tagline: 'Lenguaje SQL',
    desc: 'SQL con superpoderes: sintaxis extendida para construir data warehouses más rápido.',
    href: '/sql/',
    img: '/sql.webp',
    color: 'var(--crono-sql-color)',
    badge: 'SQL & Lenguaje',
    svgPath: '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>',
  },
]
---

<!-- ── HERO ── -->
<section class="not-content relative overflow-hidden bg-[var(--sl-color-bg-nav)] pt-12 pb-20 text-center">
    <!-- Base background to prevent abrupt color change -->
    <div class="absolute inset-0 bg-gradient-to-b from-[var(--sl-color-bg-nav)] via-[var(--sl-color-bg-nav)] to-transparent"></div>
    <!-- Subtle animated glow orbs -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div class="absolute left-1/2 top-1/2 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-[var(--sl-color-accent)] opacity-[0.05] blur-[120px] animate-pulse"></div>
      <div class="absolute left-1/4 top-1/3 h-[300px] w-[300px] rounded-full bg-cyan-400 opacity-[0.03] blur-[90px]"></div>
      <div class="absolute right-1/4 bottom-1/3 h-[250px] w-[250px] rounded-full bg-violet-400 opacity-[0.03] blur-[80px]"></div>
    </div>

    <!-- Logo -->
    <div class="relative mb-10 inline-flex items-center justify-center">
      <div class="rounded-2xl bg-[var(--sl-color-bg-nav)] border border-[var(--sl-color-hairline-light)] p-4 shadow-xl">
        <img src="/crono-logo-h-white.png" alt="Crono" class="h-12 w-auto dark-logo" />
        <img src="/crono-logo-h.png"       alt="Crono" class="h-12 w-auto light-logo" />
      </div>
    </div>

    <!-- Headline -->
    <h1 class="relative mx-auto max-w-3xl text-4xl font-extrabold leading-tight tracking-tight text-[var(--sl-color-white)] sm:text-5xl lg:text-6xl" style="margin:0 auto 1.25rem !important">
      Documentación<br/>
      <span class="bg-gradient-to-r from-[var(--sl-color-accent)] via-cyan-400 to-[var(--sl-color-accent)] bg-clip-text text-transparent bg-[length:200%_auto] animate-gradient">
        oficial de Crono
      </span>
    </h1>

    <p class="relative mx-auto max-w-2xl text-lg text-[var(--sl-color-gray-2)]" style="margin:0 auto 2.5rem !important">
      Una única plataforma para todo el proyecto BI, desde la ETL, la capa semántica, y la explotación del dato.
      <br/><strong class="text-[var(--sl-color-white)]">Fácil de usar.</strong>
    </p>

    <!-- Stat pills -->
    <div class="relative flex flex-wrap items-center justify-center gap-3">
      {[
        { icon: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>', label: '4 productos' },
        { icon: '<circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>', label: 'Siempre actualizado' },
        { icon: '<path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/>', label: 'En español' },
      ].map(s => (
        <span class="pill-badge inline-flex items-center gap-1.5 rounded-full border border-[var(--sl-color-hairline-light)] bg-[var(--sl-color-bg-nav)] px-4 py-2 text-xs font-medium text-[var(--sl-color-gray-2)] transition-all duration-200 hover:border-[var(--sl-color-accent)] hover:text-[var(--sl-color-white)] cursor-default">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
          {s.label}
        </span>
      ))}
    </div>
</section>

<!-- ── PRODUCT GRID ── -->
<section class="not-content mx-auto w-full max-w-5xl px-6 pb-24 pt-2">
    <!-- Section title simple -->
    <div class="flex flex-col items-center pb-16">
      <h2 class="text-2xl font-bold text-[var(--sl-color-white)]" style="margin:0 !important">Selecciona un manual</h2>
    </div>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {products.map((p) => (
        <a
          href={p.href}
          class="product-card group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--sl-color-hairline-light)] bg-[var(--sl-color-bg-nav)] transition-all duration-300 hover:-translate-y-2 text-decoration-none"
          style={`text-decoration:none !important; --product-color: ${p.color}`}
        >
          <!-- Glow border effect -->
          <div class="absolute inset-0 rounded-2xl opacity-0 transition-opacity duration-300 group-hover:opacity-100" style={`box-shadow: inset 0 0 0 1px ${p.color}40, 0 0 30px ${p.color}20`}></div>
          <!-- brand color top strip -->
          <div class="h-1 w-full" style={`background: linear-gradient(90deg, ${p.color}80, ${p.color}40)`}></div>

          <div class="flex flex-1 flex-col p-6">
            <!-- header row -->
            <div class="mb-4 flex items-start justify-between gap-3">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl" style={`background: ${p.color}15; color: ${p.color}`}>
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={p.svgPath} />
                </div>
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-widest text-[var(--sl-color-gray-3)]" style="margin:0 !important">{p.tagline}</p>
                  <h2 class="text-base font-bold text-[var(--sl-color-white)]" style="margin:0 !important">{p.name}</h2>
                </div>
              </div>
            </div>

            <!-- desc -->
            <p class="flex-1 text-sm leading-relaxed text-[var(--sl-color-gray-2)]" style="margin:0 0 1.25rem !important">{p.desc}</p>

            <!-- footer -->
            <div class="flex items-center justify-between">
              <span class="rounded-full border border-current px-2.5 py-0.5 text-[10px] font-semibold opacity-70" style={`color: ${p.color}; border-color: ${p.color}`}>
                {p.badge}
              </span>
              <span class="flex items-center gap-1 text-xs font-semibold transition-gap duration-150" style={`color: ${p.color}`}>
                Ver manual
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-1">
                  <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                </svg>
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Footer with divider -->
    <div class="pt-20 pb-10 flex flex-col items-center gap-6">
      <div class="h-[2px] w-full max-w-3xl bg-gradient-to-r from-transparent via-[var(--sl-color-accent)] to-transparent opacity-60"></div>
      <p class="text-sm text-[var(--sl-color-gray-3)]" style="margin:0 !important">
        Made by Crono with ❤️
      </p>
    </div>
</section>

<style>
  /* Crono product brand colors (from official images) */
  :root {
    --crono-analysis-color: #C85A47;
    --crono-metadata-color: #5B2C7D;
    --crono-etl-color: #1B8AC7;
    --crono-sql-color: #1B5F8C;
  }

  /* Gradient text animation */
  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .animate-gradient {
    animation: gradient-shift 8s ease infinite;
  }

  /* Pulse animation for background glows */
  @keyframes pulse {
    0%, 100% { opacity: 0.08; transform: translate(-50%, -50%) scale(1); }
    50% { opacity: 0.12; transform: translate(-50%, -50%) scale(1.05); }
  }

  /* Pill badge hover glow */
  .pill-badge:hover {
    box-shadow: 0 0 20px var(--sl-color-accent);
  }

  /* Product card hover shadow */
  .product-card:hover {
    box-shadow: 0 20px 40px -10px rgba(0,0,0,0.3);
  }

  /* dark/light logo toggle — Starlight sets data-theme on <html> */
  :root[data-theme='light'] .dark-logo  { display: none; }
  :root[data-theme='dark']  .light-logo { display: none; }
  /* default (no attribute = dark in Starlight) */
  :root:not([data-theme='light']) .light-logo { display: none; }
</style>
