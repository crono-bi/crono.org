    padding: 0 16px;
    margin-bottom: 2px;
  }

  .ecosystem-header-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--sl-color-accent);
    margin-bottom: 0.1rem;
    padding: 0.25rem 0.6rem;
    background: linear-gradient(135deg, color-mix(in srgb, var(--sl-color-accent) 12%, transparent), color-mix(in srgb, var(--sl-color-accent) 4%, transparent));
    border: 1px solid color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
    border-radius: 999px;
  }

  .ecosystem-header-icon {
    font-size: 0.6rem;
    opacity: 0.9;
  }

  .ecosystem-header-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    margin-bottom: 0px;
  }

  .ecosystem-header-accent {
    background: linear-gradient(135deg, #F97316, #FBBF24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .ecosystem-header-desc {
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    line-height: 2;
    color: var(--sl-color-accent);
    max-width: 60ch;
    margin: 0.6rem auto 0;
    margin-bottom: 0px;
  }

  .ecosystem-header-desc strong {
    color: var(--sl-color-gray-2);
    font-weight: 600;
  }

  .ecosystem-label {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--sl-color-accent);
    margin-bottom: 0.75rem;
  }
  .ecosystem-label::before {
    content: '';
    width: 1rem;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
  }
  .ecosystem-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
    margin-bottom: 0.9rem;
    max-width: 18ch;
  }
  .ecosystem-desc {
    font-size: 1rem;
    line-height: 1.75;
    color: var(--sl-color-gray-3);
    max-width: 56ch;
    margin-bottom: 1rem;
  }
  .ecosystem-points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.5rem;
  }
  .ecosystem-points li {
    color: var(--sl-color-gray-2);
    font-size: 0.95rem;
    line-height: 1.45;
    position: relative;
    padding-left: 1.2rem;
  }
  .ecosystem-points li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 0.05rem;
    color: var(--sl-color-accent);
    font-weight: 700;
  }

  .ecosystem-map {
    position: relative;
    min-height: 430px;
    border-radius: 1rem;
    border: 0;
    background: transparent;
    box-shadow: none;
    overflow: hidden;
  }
  .eco-source,
  .eco-core {
    position: absolute;
    width: 170px;
    height: 170px;
    border-radius: 999px;
    border: 1px solid #d5dcef;
    background: radial-gradient(circle at 35% 25%, #f8fafc 0%, #edf2fb 100%);
    box-shadow: 0 12px 24px -18px rgba(15, 23, 42, 0.45);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 1rem;
  }
  .eco-source { left: 0.25rem; top: 50%; transform: translateY(-50%); }
  .eco-core { left: 36%; top: 50%; transform: translate(-50%, -50%); }
  .eco-source-title, .eco-core-title {
    font-size: 1rem;
    font-weight: 800;
    color: #1f2937;
    letter-spacing: -0.02em;
  }
  .eco-source-sub, .eco-core-sub {
    margin-top: 0.3rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #6b7280;
  }
  .eco-source-connector {
    position: absolute;
    left: 174px;
    top: 50%;
    width: 82px;
    height: 2px;
    transform: translateY(-50%);
    background: linear-gradient(90deg, #3b82f6, #8b5cf6);
  }
  .eco-core-arcs {
    position: absolute;
    left: 36%;
    top: 50%;
    width: 220px;
    height: 220px;
    transform: translate(-50%, -50%);
    border-radius: 999px;
    border: 3px solid transparent;
    border-right-color: #2ec5ce;
    border-bottom-color: #f97362;
    border-top-color: #148a62;
    opacity: 0.8;
  }
  .eco-tile {
    position: absolute;
    width: 96px;
    height: 96px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 800;
    text-decoration: none;
    color: #334155;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    box-shadow: 0 10px 22px -18px rgba(15, 23, 42, 0.55);
    transform-origin: center;
  }
  .eco-tile-analysis { top: 8%; left: 49%; transform: rotate(16deg); color: #c85a47; }
  .eco-tile-excel { top: 26%; left: 58%; transform: rotate(15deg); color: #15803d; }
  .eco-tile-ai { top: 46%; left: 62%; transform: rotate(10deg); color: #0ea5b7; }
  .eco-tile-api { top: 66%; left: 57%; transform: rotate(8deg); color: #fb7185; }
  .eco-tile-bi { top: 82%; left: 50%; transform: rotate(-2deg); color: #f59e0b; }

  .eco-callouts {
    position: absolute;
    top: 2%;
    right: 0;
    width: 210px;
    display: grid;
    gap: 0.65rem;
  }
  .eco-callout {
    border-left: 2px solid #d5dcef;
    padding-left: 0.65rem;
  }
  .eco-callout h4 {
    margin: 0;
    font-size: 0.84rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #334155;
  }
  .eco-callout p {
    margin: 0.2rem 0 0;
    font-size: 0.78rem;
    line-height: 1.35;
    color: #64748b;
  }

  @media (max-width: 1024px) {
    .ecosystem-title { max-width: 100%; }
    .ecosystem-map { min-height: 470px; }
    .eco-callouts { width: 180px; }
  }
  @media (max-width: 640px) {
    .ecosystem-map {
      min-height: auto;
      padding: 0.25rem 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .eco-source-connector,
    .eco-core-arcs,
    .eco-callouts,
    .eco-tile {
      display: none;
    }
    .eco-source,
    .eco-core {
      position: static;
      transform: none;
      width: 100%;
      height: auto;
      border-radius: 0.85rem;
      padding: 0.85rem;
    }
    .ecosystem-map a.eco-mobile-link {
      position: static;
    }
  }

  /* Stats row */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 1.75rem;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-stat-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 6px;
    background: color-mix(in srgb, var(--si-color) 12%, transparent);
    color: var(--si-color);
    margin-bottom: 4px;
  }

  .hero-stat-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--sl-color-white);
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .hero-stat-label {
    font-size: 0.6875rem;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .hero-stat-divider {
    width: 1px;
    height: 28px;
    background: var(--sl-color-hairline);
    opacity: 0.6;
  }

  /* Mock Window */
  .mock-window {
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -15px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.04);
  }

  .mock-bar {
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline-light);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 80%, var(--sl-color-bg));
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .mock-bar-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
  }

  .mock-win-controls {
    display: flex;
    gap: 0;
    flex-shrink: 0;
  }

  .mock-win-btn {
    width: 34px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sl-color-gray-3);
    transition: background 0.15s ease, color 0.15s ease;
  }

  .mock-win-btn:hover {
    background: color-mix(in srgb, var(--sl-color-gray-4) 15%, transparent);
    color: var(--sl-color-white);
  }

  .mock-win-btn.close:hover {
    background: #e81123;
    color: #ffffff;
  }

  .mock-body { padding: 0.375rem; }

  .mock-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    text-decoration: none;
    color: var(--sl-color-text);
    border-radius: 0.5rem;
    transition: background 0.15s ease, transform 0.15s ease;
    cursor: pointer;
  }

  .mock-row + .mock-row {
    border-top: 1px solid var(--sl-color-hairline-light);
    border-radius: 0;
  }

  .mock-row:first-child { border-radius: 0.5rem 0.5rem 0 0; }
  .mock-row:last-child  { border-radius: 0 0 0.5rem 0.5rem; }

  .mock-row:hover {
    background: color-mix(in srgb, var(--row-color) 10%, var(--sl-color-bg-nav));
    transform: translateX(2px);
  }

  .mock-icon-wrap {
    width: 32px;
    height: 32px;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--row-color) 15%, transparent);
    border: 1px solid color-mix(in srgb, var(--row-color) 25%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--row-color);
    flex-shrink: 0;
    transition: background 0.15s ease;
  }

  .mock-row:hover .mock-icon-wrap {
    background: color-mix(in srgb, var(--row-color) 25%, transparent);
  }

  .mock-col { flex: 1; display: flex; flex-direction: column; gap: 2px; }
  .mock-name { font-size: 0.8125rem; font-weight: 600; color: var(--sl-color-white); }
  .mock-sub { font-size: 0.6875rem; color: var(--sl-color-gray-3); }

  .mock-chevron {
    color: var(--sl-color-gray-4);
    flex-shrink: 0;
    transition: color 0.15s ease, transform 0.15s ease;
  }

  .mock-row:hover .mock-chevron {
    color: var(--row-color);
    transform: translateX(2px);
  }

  .mock-doc-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    text-decoration: none;
    border-radius: 6px;
    background: color-mix(in srgb, var(--row-color) 12%, transparent);
    border: 1px solid color-mix(in srgb, var(--row-color) 30%, transparent);
    transition: all 0.2s ease;
    opacity: 0.85;
    position: relative;
    z-index: 1;
    cursor: pointer;
    flex-shrink: 0;
  }

  .mock-doc-btn svg {
    width: 16px;
    height: 16px;
    color: var(--row-color);
    stroke-width: 2;
  }

  .mock-doc-btn:hover {
    background: color-mix(in srgb, var(--row-color) 25%, transparent);
    border-color: color-mix(in srgb, var(--row-color) 50%, transparent);
    opacity: 1;
    transform: scale(1.08);
  }

  /* Section label with divider lines */
  .hero-section-label {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .label-line {
    flex: 1;
    max-width: 80px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--sl-color-hairline-light), transparent);
  }

  .label-text {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* Tagline text */
  .hero-tagline {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    letter-spacing: 0.02em;
    margin: 0;
  }

  /* Product Cards */
  .hero-products-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 640px) {
    .hero-products-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .hero-products-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .hero-product-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    animation: card-enter 0.6s ease-out backwards;
    animation-delay: calc(var(--index) * 0.1s);
  }

  @keyframes card-enter {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-product-card:hover {
    transform: translateY(-6px);
    border-color: var(--product-color);
    box-shadow: 0 24px 48px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px var(--product-color);
  }

  .hero-card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    background: radial-gradient(400px circle at 50% 0%,
      color-mix(in srgb, var(--product-color) 15%, transparent),
      transparent 50%);
    pointer-events: none;
  }

  .hero-product-card:hover .hero-card-glow {
    opacity: 1;
  }

  .hero-card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 2rem;
  }

  .hero-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }

  .hero-card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 1rem;
    transition: transform 0.3s ease;
  }

  .hero-product-card:hover .hero-card-icon {
    transform: scale(1.08);
  }

  .hero-card-badge {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  .hero-card-title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .hero-card-tagline {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--product-color);
    margin: 0 0 1rem;
  }

  .hero-card-desc {
    font-size: 0.9375rem;
    line-height: 1.65;
    color: var(--sl-color-gray-2);
    margin: 0;
    flex: 1;
  }

  .hero-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }

  .hero-card-link {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    transition: color 0.3s ease;
  }

  .hero-product-card:hover .hero-card-link {
    color: var(--product-color);
  }

  .hero-card-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--sl-color-bg-nav);
    color: var(--sl-color-gray-3);
    transition: all 0.3s ease;
  }

  .hero-product-card:hover .hero-card-arrow {
    background: var(--product-color);
    color: white;
    transform: translateX(3px);
  }

  .hero-card-border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    transform: scaleX(0);
    transition: transform 0.4s ease;
  }

  .hero-product-card:hover .hero-card-border {
    transform: scaleX(1);
  }
  
  /* ═══════════════════════════════════════════════════════════════
     CODE WINDOW
     ═══════════════════════════════════════════════════════════════ */
  
  .code-window-wrapper {
    position: relative;
  }
  
  .code-window {
    background: #0d1117;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #30363d;
    box-shadow: 
      0 20px 50px -20px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.05) inset;
  }
  
  .code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 1rem;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }

  .code-title {
    font-size: 0.75rem;
    font-family: ui-monospace, monospace;
    color: #8b949e;
  }
  
  .code-body {
    padding: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  
  .code-body :global(pre) {
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
  }
  
  /* Floating badges */
  .floating-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-1);
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.3);
    animation: badge-float 6s ease-in-out infinite;
  }
  
  .badge-1 {
    top: 10%;
    right: -20px;
  }
  
  .badge-2 {
    bottom: 15%;
    left: -30px;
    animation-delay: -3s;
  }
  
  @keyframes badge-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  /* ═══════════════════════════════════════════════════════════════
     BENTO GRID
     ═══════════════════════════════════════════════════════════════ */
  
  .bento-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  
  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
    }
    
    .bento-card-large {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
  
  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .bento-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-color);
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.4);
  }
  
  .card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
      color-mix(in srgb, var(--card-color) 15%, transparent), 
      transparent 40%);
  }
  
  .bento-card:hover .card-glow {
    opacity: 1;
  }
  
  .card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.75rem;
  }
  
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  
  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.875rem;
  }
  
  .card-badge {
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
  }
  
  .card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0;
    flex: 1;
  }
  
  .card-footer {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }
  
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-accent);
    transition: gap 0.2s ease;
  }
  
  .bento-card:hover .card-cta {
    gap: 0.75rem;
  }
  
  .card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  
  .bento-card:hover .card-accent {
    transform: scaleX(1);
  }
  
  /* Large card specific */
  .bento-card-large .card-content {
    padding: 2rem;
  }
  
  .bento-card-large .card-title {
    font-size: 1.5rem;
  }
  
  .bento-card-large .card-desc {
    font-size: 1rem;
    max-width: 400px;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     PRODUCT SECTIONS
     ═══════════════════════════════════════════════════════════════ */
  
  .product-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--sl-color-hairline);
  }

  /* ═══════════════════════════════════════════════════════════════
     SCROLL REVEAL ANIMATIONS
     ═══════════════════════════════════════════════════════════════ */

  .scroll-reveal {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children animation */
  .scroll-reveal .product-content {
    opacity: 1;
    transform: translateX(0);
  }

  .scroll-reveal .product-demo {
    opacity: 0;
    transform: translateX(30px);
    transition: all 0.6s ease-out 0.3s;
  }

  .scroll-reveal.is-visible .product-demo {
    opacity: 1;
    transform: translateX(0);
  }

  /* Alternating sides */
  .scroll-reveal:nth-child(even) .product-content {
    opacity: 1;
    transform: translateX(0);
  }

  .scroll-reveal:nth-child(even) .product-demo {
    opacity: 0;
    transform: translateX(-30px);
    transition-delay: 0.2s;
  }

  .scroll-reveal:nth-child(even).is-visible .product-demo {
    opacity: 1;
    transform: translateX(0);
  }

  .section-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  
  .product-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .product-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, currentColor 12%, transparent);
    width: fit-content;
  }
  
  .product-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--sl-color-white);
    margin: 0;
  }
  
  .product-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 480px;
  }
  
  .product-features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  
  .product-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
  }
  
  .btn-product {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    border: none;
    box-sizing: border-box;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 4px 8px -2px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .btn-product:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .btn-product:active {
    transform: translateY(0);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      inset 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .btn-product-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    border: 1.5px solid currentColor;
    background: transparent;
    box-sizing: border-box;
    box-shadow: inset 0 0 0 transparent;
  }

  .btn-product-secondary:hover {
    transform: translateY(-1px);
    background: color-mix(in srgb, currentColor 8%, transparent);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      0 4px 8px -2px color-mix(in srgb, currentColor 15%, transparent);
  }

  .btn-product-secondary:active {
    transform: translateY(0);
    background: color-mix(in srgb, currentColor 12%, transparent);
  }

  /* Product Actions - Multiple buttons */
  .product-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .product-actions .btn-product,
  .product-actions .btn-product-secondary {
    margin-top: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     PLAYGROUND BRAND - Blue (#3B82F6)
     ═══════════════════════════════════════════════════════════════ */
  .btn-playground-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.5rem;
    color: #3B82F6;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.625rem;
    text-decoration: none;
    border: 2px solid #3B82F6;
    background: rgba(59, 130, 246, 0.08);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .btn-playground-secondary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-playground-secondary:hover {
    transform: translateY(-2px) scale(1.02);
    background: #3B82F6;
    color: #fff;
    box-shadow: 
      0 4px 20px -4px rgba(59, 130, 246, 0.5),
      0 0 0 1px rgba(59, 130, 246, 0.3) inset;
  }

  .btn-playground-secondary:hover::before {
    opacity: 1;
  }

  .btn-playground-secondary svg {
    stroke: currentColor;
    transition: transform 0.2s ease;
  }

  .btn-playground-secondary:hover svg {
    transform: translateX(2px);
  }

  /* Code Window Playground Link - Yellow Ochre */
  .code-playground-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    color: #fff;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.5rem;
    background: #3B82F6;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
      0 2px 8px -2px rgba(59, 130, 246, 0.4),
      0 0 0 1px rgba(0, 0, 0, 0.1) inset;
    position: relative;
    overflow: hidden;
  }

  .code-playground-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .code-playground-link:hover {
    transform: translateY(-1px) scale(1.02);
    background: #60A5FA;
    box-shadow: 
      0 4px 16px -2px rgba(59, 130, 246, 0.5),
      0 0 0 1px rgba(0, 0, 0, 0.05) inset;
  }

  .code-playground-link:hover::before {
    opacity: 1;
  }

  .code-playground-link svg {
    stroke: #fff;
    stroke-width: 2.5;
    transition: transform 0.2s ease;
  }

  .code-playground-link:hover svg {
    transform: translateX(1px);
  }
  
  /* Product Demo */
  .product-demo {
    position: relative;
  }
  
  .demo-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-1);
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.3);
    animation: demo-float 5s ease-in-out infinite;
  }
  
  @keyframes demo-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  
  .demo-badge-1 {
    animation-delay: 0s;
  }

  @media (max-width: 768px) {
    /* ETL: ocultar preview Calendas flotante */
    .calendas-preview {
      display: none;
    }

    /* API demo: ocultar elementos flotantes y contener el mockup */
    .api-demo-wrap {
      overflow: hidden;
      padding-bottom: 0;
    }
    .api-float-chart {
      display: none;
    }
    .api-float-response {
      position: static;
      width: 100%;
      margin-top: 0.5rem;
      border-radius: 0.5rem;
    }
    .swagger-path {
      flex-shrink: 1;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      min-width: 0;
    }
    .swagger-endpoint {
      gap: 0.375rem;
    }

    /* Ocultar badges flotantes que desbordan en mobile */
    .demo-badge {
      display: none;
    }

    /* Contener mockups dentro del viewport */
    .product-demo {
      overflow: hidden;
      max-width: 100%;
    }

    /* Código con scroll horizontal en vez de desborde */
    .code-window,
    .pipeline-window,
    .catalog-window,
    .dashboard-window,
    .swagger-window,
    .ai-window,
    .excel-window {
      max-width: 100%;
      overflow-x: auto;
    }

    .code-body pre,
    .code-block {
      overflow-x: auto;
      white-space: pre;
      font-size: 0.75rem;
    }

    /* Reducir padding lateral en secciones producto */
    .product-section .mx-auto {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    /* Título de producto más pequeño en mobile */
    .product-title {
      font-size: clamp(1.5rem, 6vw, 2rem);
    }

    /* Botones en columna en mobile */
    .product-actions {
      flex-direction: column;
      align-items: flex-start;
    }

    .btn-product,
    .btn-product-secondary {
      width: 100%;
      justify-content: center;
    }
  }
  
  .demo-badge-2 {
    animation-delay: -2.5s;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     CATALOG WINDOW (Metadata)
     ═══════════════════════════════════════════════════════════════ */
  
  .catalog-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
  }
  
  .catalog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #5B2C7D 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .catalog-header svg {
    color: #5B2C7D;
    order: 1;
  }

  .catalog-header::after {
    content: '— □ ×';
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
    order: 2;
  }
  
  .catalog-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .catalog-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    transition: background 0.2s;
  }
  
  .catalog-item:hover,
  .catalog-item.active {
    background: color-mix(in srgb, #5B2C7D 10%, transparent);
  }
  
  .catalog-icon {
    font-size: 1rem;
    opacity: 0.7;
  }
  
  .catalog-icon.dim { color: #5B2C7D; }
  .catalog-icon.fact { color: #C85A47; }
  .catalog-icon.ind { color: #1B5F8C; }
  
  .catalog-name {
    flex: 1;
    font-weight: 500;
    color: var(--sl-color-white);
  }
  
  .catalog-type {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg);
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     SWAGGER WINDOW (API)
     ═══════════════════════════════════════════════════════════════ */

  .swagger-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid color-mix(in srgb, #0EA5E9 25%, var(--sl-color-hairline-light));
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #0EA5E9 8%, transparent),
      0 20px 50px -15px rgba(0,0,0,0.5);
  }

  .swagger-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, #0EA5E9 12%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .swagger-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .swagger-version {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #0EA5E9 20%, transparent);
    color: #0EA5E9;
    border: 1px solid color-mix(in srgb, #0EA5E9 30%, transparent);
  }

  .swagger-oas {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
    margin-left: auto;
  }

  .swagger-body {
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .swagger-endpoint {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid transparent;
    transition: background 0.15s ease;
    cursor: default;
  }

  .swagger-endpoint.get { border-color: color-mix(in srgb, #0EA5E9 20%, transparent); background: color-mix(in srgb, #0EA5E9 5%, transparent); }
  .swagger-endpoint.post { border-color: color-mix(in srgb, #22c55e 20%, transparent); background: color-mix(in srgb, #22c55e 5%, transparent); }
  .swagger-endpoint.delete { border-color: color-mix(in srgb, #ef4444 20%, transparent); background: color-mix(in srgb, #ef4444 5%, transparent); }

  .swagger-method {
    font-size: 0.65rem;
    font-weight: 800;
    font-family: monospace;
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    min-width: 36px;
    text-align: center;
    flex-shrink: 0;
  }

  .swagger-method.get { background: #0EA5E9; color: #fff; }
  .swagger-method.post { background: #22c55e; color: #fff; }
  .swagger-method.delete { background: #ef4444; color: #fff; }

  .swagger-path {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--sl-color-white);
    font-weight: 500;
    flex-shrink: 0;
  }

  .swagger-desc {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .swagger-status {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .swagger-status.s200 { background: color-mix(in srgb, #22c55e 20%, transparent); color: #22c55e; }
  .swagger-status.s204 { background: color-mix(in srgb, #0EA5E9 20%, transparent); color: #0EA5E9; }

  .swagger-endpoint-active {
    box-shadow: 0 0 0 1px color-mix(in srgb, #22c55e 40%, transparent);
  }

  /* ── API demo wrapper ── */
  .api-demo-wrap {
    position: relative;
    padding-bottom: 3rem;
  }

  /* ── Floating JSON response ── */
  .api-float-response {
    position: absolute;
    bottom: -0.5rem;
    right: -1rem;
    width: 230px;
    background: var(--sl-color-bg);
    border: 1px solid color-mix(in srgb, #22c55e 30%, var(--sl-color-hairline-light));
    border-radius: 0.625rem;
    overflow: hidden;
    box-shadow: 0 8px 24px -6px rgba(0,0,0,0.45);
    z-index: 2;
  }

  .api-float-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.625rem;
    background: color-mix(in srgb, #22c55e 10%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.7rem;
  }

  .api-float-label {
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .api-float-latency {
    color: #facc15;
    margin-left: auto;
  }

  .api-float-code.s200 {
    font-weight: 700;
    color: #22c55e;
    font-size: 0.65rem;
  }

  .api-float-body {
    margin: 0;
    padding: 0.5rem 0.625rem;
    font-size: 0.7rem;
    line-height: 1.6;
    font-family: monospace;
    background: transparent;
    white-space: pre;
    overflow: hidden;
  }

  .json-bracket { color: var(--sl-color-gray-2); }
  .json-brace   { color: var(--sl-color-gray-2); }
  .json-key     { color: #93c5fd; }
  .json-str     { color: #86efac; }
  .json-num     { color: #fda4af; }

  /* ── Floating sparkline chart ── */
  .api-float-chart {
    position: absolute;
    top: -1rem;
    right: -1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid color-mix(in srgb, #0EA5E9 25%, var(--sl-color-hairline-light));
    border-radius: 0.625rem;
    padding: 0.5rem 0.75rem;
    box-shadow: 0 4px 16px -4px rgba(0,0,0,0.4);
    z-index: 3;
    min-width: 110px;
  }

  .api-chart-label {
    font-size: 0.65rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.35rem;
    white-space: nowrap;
  }

  .api-sparkline {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 28px;
    margin-bottom: 0.35rem;
  }

  .api-sparkline span {
    flex: 1;
    background: #0EA5E9;
    border-radius: 2px 2px 0 0;
    opacity: 0.85;
    min-height: 3px;
  }

  .api-sparkline span:last-child {
    opacity: 1;
    background: #38bdf8;
  }

  .api-chart-value {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1;
  }

  .api-chart-value span {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--sl-color-gray-3);
  }

  /* ── Metric pills ── */
  .api-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .api-pill {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .api-pill.green { background: color-mix(in srgb, #22c55e 12%, transparent); color: #22c55e; border-color: color-mix(in srgb, #22c55e 25%, transparent); }
  .api-pill.blue  { background: color-mix(in srgb, #0EA5E9 12%, transparent); color: #0EA5E9; border-color: color-mix(in srgb, #0EA5E9 25%, transparent); }
  .api-pill.purple{ background: color-mix(in srgb, #8B5CF6 12%, transparent); color: #8B5CF6; border-color: color-mix(in srgb, #8B5CF6 25%, transparent); }

  /* ═══════════════════════════════════════════════════════════════
     DASHBOARD WINDOW (Analysis)
     ═══════════════════════════════════════════════════════════════ */
  
  .dashboard-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
  }
  
  .dashboard-header {
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #C85A47 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .dashboard-header::after {
    content: '— □ ×';
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }

  .dashboard-tabs {
    display: flex;
    gap: 1rem;
  }
  
  .dashboard-tabs .tab {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    padding: 0.375rem 0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }
  
  .dashboard-tabs .tab.active {
    color: var(--sl-color-white);
    border-bottom-color: #C85A47;
  }
  
  .dashboard-body {
    padding: 1.5rem;
  }
  
  .chart-container {
    margin-bottom: 1.5rem;
  }
  
  .chart-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  
  .chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    gap: 0.75rem;
    height: 120px;
    padding: 0 0.5rem;
  }
  
  .chart-bars .bar {
    flex: 1;
    max-width: 40px;
    background: color-mix(in srgb, #C85A47 30%, var(--sl-color-gray-5));
    border-radius: 0.25rem 0.25rem 0 0;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .chart-bars .bar.active {
    background: #C85A47;
  }
  
  .chart-bars .bar label {
    position: absolute;
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6875rem;
    color: var(--sl-color-gray-3);
  }
  
  .kpi-row {
    display: flex;
    gap: 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }
  
  .kpi {
    flex: 1;
  }
  
  .kpi-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }
  
  .kpi-label {
    display: block;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    margin-top: 0.25rem;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     PIPELINE WINDOW (ETL)
     ═══════════════════════════════════════════════════════════════ */
  
  .pipeline-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
  }
  
  .pipeline-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #1B8AC7 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .pipeline-header svg {
    color: #1B8AC7;
    order: 1;
  }

  .pipeline-header span {
    order: 1;
  }

  .pipeline-header::after {
    content: '— □ ×';
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
    order: 2;
  }
  
  .pipeline-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
  }
  
  .pipeline-step {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem;
    border-radius: 0.625rem;
    background: var(--sl-color-bg);
  }
  
  .pipeline-step.done {
    background: color-mix(in srgb, #22c55e 10%, var(--sl-color-bg));
  }
  
  .pipeline-step.running {
    background: color-mix(in srgb, #1B8AC7 15%, var(--sl-color-bg));
    border: 1px solid color-mix(in srgb, #1B8AC7 30%, transparent);
  }
  
  .step-icon {
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  
  .pipeline-step.done .step-icon {
    background: #22c55e;
    color: white;
  }
  
  .pipeline-step.running .step-icon {
    background: #1B8AC7;
    color: white;
    animation: pulse 2s infinite;
  }
  
  .pipeline-step.pending .step-icon {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-gray-3);
  }
  
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.6; }
  }
  
  .step-info {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  
  .step-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }
  
  .step-time {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }
  
  .pipeline-connector {
    width: 2px;
    height: 1.25rem;
    background: var(--sl-color-hairline-light);
    margin-left: 1.75rem;
  }
  
  .pipeline-connector.done {
    background: #22c55e;
    opacity: 0.3;
  }

  /* ═══════════════════════════════════════════════════════════════
     CALENDAS PREVIEW (ETL Integration)
     ═══════════════════════════════════════════════════════════════ */

  .calendas-preview {
    position: absolute;
    right: -20px;
    bottom: -20px;
    z-index: 10;
  }

  .heatmap-mini {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.75rem;
    padding: 0.75rem;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
    width: 140px;
  }

  .heatmap-title {
    font-size: 0.625rem;
    font-weight: 700;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
    text-align: center;
  }

  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    margin-bottom: 0.5rem;
  }

  .h-cell {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 2px;
  }

  .h-cell.success {
    background: #22c55e;
    opacity: 0.8;
  }

  .h-cell.warning {
    background: #f59e0b;
    opacity: 0.8;
  }

  .h-cell.error {
    background: #ef4444;
    opacity: 0.8;
  }

  .h-cell.running {
    background: #3b82f6;
    animation: pulse-heatmap 2s infinite;
  }

  .h-cell.empty {
    background: var(--sl-color-gray-6);
    opacity: 0.3;
  }

  @keyframes pulse-heatmap {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
  }

  .heatmap-stats {
    font-size: 0.5625rem;
    color: var(--sl-color-gray-3);
    text-align: center;
    font-weight: 500;
  }

  .calendas-badge {
    background: color-mix(in srgb, #10b981 15%, var(--sl-color-bg-nav)) !important;
    border-color: color-mix(in srgb, #10b981 30%, transparent) !important;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .calendas-badge:hover {
    background: color-mix(in srgb, #10b981 25%, var(--sl-color-bg-nav)) !important;
    border-color: color-mix(in srgb, #10b981 50%, transparent) !important;
    transform: translateY(-2px);
    box-shadow: 0 6px 24px -4px rgba(16, 185, 129, 0.3);
  }

  /* ═══════════════════════════════════════════════════════════════
     SECTION TRANSITION
     ═══════════════════════════════════════════════════════════════ */

  .section-transition {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 2rem 3rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .section-transition-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      color-mix(in srgb, #3B82F6 30%, var(--sl-color-hairline)) 50%,
      transparent
    );
  }

  .section-transition-label {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, #3B82F6 80%, var(--sl-color-gray-3));
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     PLAYGROUND INLINE STATS
     ═══════════════════════════════════════════════════════════════ */

  .playground-stats {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, #3B82F6 6%, var(--sl-color-bg-nav));
    border: 1px solid color-mix(in srgb, #3B82F6 20%, var(--sl-color-hairline));
    border-radius: 0.75rem;
    width: fit-content;
  }

  .playground-stat {
    display: flex;
    align-items: baseline;
    gap: 0.4rem;
    padding: 0 1.25rem;
  }

  .playground-stat:first-child { padding-left: 0; }
  .playground-stat:last-child  { padding-right: 0; }

  .playground-stat-number {
    font-size: 1.375rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #3B82F6;
    line-height: 1;
  }

  .playground-stat-label {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }

  .playground-stat-sep {
    width: 1px;
    height: 1.5rem;
    background: color-mix(in srgb, #3B82F6 25%, var(--sl-color-hairline));
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     PLAYGROUND SECTION
     ═══════════════════════════════════════════════════════════════ */

  .playground-section {
    position: relative;
    overflow: hidden;
    background: color-mix(in srgb, #3B82F6 4%, var(--sl-color-bg-nav));
    border-top: 2px solid color-mix(in srgb, #3B82F6 25%, var(--sl-color-hairline));
  }

  .playground-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 70% 50% at 80% 50%,
        color-mix(in srgb, #3B82F6 8%, transparent) 0%,
        transparent 70%);
    pointer-events: none;
  }

  .playground-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .playground-label {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.875rem;
    background: color-mix(in srgb, #3B82F6 12%, transparent);
    border: 1px solid color-mix(in srgb, #3B82F6 25%, transparent);
    border-radius: 2rem;
    font-size: 0.8125rem;
    font-weight: 600;
    color: #3B82F6;
    width: fit-content;
  }

  .playground-label svg { opacity: 0.8; }

  .playground-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--sl-color-white);
    margin: 0;
  }

  .playground-title-accent {
    background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .playground-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 480px;
  }

  .playground-features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .playground-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
  }

  .playground-check {
    color: #3B82F6;
    font-weight: 600;
  }

  .playground-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.5rem;
    background: linear-gradient(135deg, #3B82F6 0%, #2563EB 100%);
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.625rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.2s ease;
    width: fit-content;
    box-shadow: 0 4px 14px -4px rgba(59, 130, 246, 0.4);
  }

  .playground-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.1);
    box-shadow: 0 8px 24px -6px rgba(59, 130, 246, 0.5);
  }

  /* Playground Demo Window */
  .playground-demo {
    position: relative;
  }

  .playground-demo::before {
    content: '';
    position: absolute;
    inset: -20px;
    background: radial-gradient(ellipse 80% 60% at 50% 50%, color-mix(in srgb, #3B82F6 12%, transparent), transparent);
    pointer-events: none;
    z-index: -1;
  }

  .playground-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid color-mix(in srgb, #3B82F6 20%, var(--sl-color-hairline-light));
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #3B82F6 8%, transparent),
      0 25px 70px -15px rgba(0, 0, 0, 0.6),
      0 0 80px -20px color-mix(in srgb, #3B82F6 20%, transparent);
  }

  .playground-window-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #3B82F6 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .playground-window-tabs {
    display: flex;
    gap: 0.5rem;
  }

  .playground-window-tabs .tab {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
    cursor: pointer;
  }

  .playground-window-tabs .tab.active {
    background: var(--sl-color-bg);
    color: var(--sl-color-white);
  }

  .playground-window-btns {
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }

  .playground-window-body {
    display: flex;
    min-height: 220px;
  }

  .playground-editor-pane {
    flex: 1;
    padding: 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.8125rem;
    line-height: 1.6;
  }

  .playground-gutter {
    width: 8px;
    background: var(--sl-color-bg);
    border-left: 1px solid var(--sl-color-hairline-light);
    border-right: 1px solid var(--sl-color-hairline-light);
    cursor: col-resize;
  }

  .playground-output-pane {
    flex: 1;
    padding: 1rem;
    font-family: ui-monospace, monospace;
    font-size: 0.8125rem;
    line-height: 1.6;
    background: color-mix(in srgb, var(--sl-color-bg) 50%, var(--sl-color-bg-nav));
  }

  .playground-code-line {
    display: flex;
    gap: 0.75rem;
    white-space: nowrap;
  }

  .playground-code-line.dim {
    opacity: 0.6;
  }

  .line-num {
    color: var(--sl-color-gray-4);
    font-size: 0.75rem;
    min-width: 1.5rem;
    text-align: right;
  }

  .playground-code-line .kw { color: #ff7b72; }
  .playground-code-line .cr { color: #79c0ff; font-weight: 600; }
  .playground-code-line .cs { color: #d2a8ff; }
  .playground-code-line .id { color: #e6edf3; }

  .playground-window-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg);
    border-top: 1px solid var(--sl-color-hairline-light);
    font-size: 0.75rem;
  }

  .playground-dialect-selector {
    display: flex;
    gap: 1rem;
  }

  .playground-dialect-selector .dialect {
    color: var(--sl-color-gray-3);
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .playground-dialect-selector .dialect.active {
    color: #3B82F6;
    font-weight: 500;
  }

  .playground-status {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--sl-color-gray-3);
  }

  .status-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .status-dot.success {
    background: #3B82F6;
  }

  /* Playground mobile fixes */
  @media (max-width: 640px) {
    .playground-stats {
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: 0.75rem 1rem;
      width: 100%;
      max-width: 100%;
    }
    .playground-stat {
      padding: 0 0.75rem;
      flex: 1;
      min-width: calc(50% - 0.5rem);
      justify-content: center;
    }
    .playground-stat:first-child { padding-left: 0; }
    .playground-stat:last-child { padding-right: 0; }
    .playground-stat-label {
      font-size: 0.7rem;
      white-space: normal;
    }
    .playground-stat-sep {
      display: none;
    }
    .playground-window-body {
      flex-direction: column;
      min-height: auto;
    }
    .playground-gutter {
      width: 100%;
      height: 6px;
      border-left: none;
      border-right: none;
      border-top: 1px solid var(--sl-color-hairline-light);
      border-bottom: 1px solid var(--sl-color-hairline-light);
      cursor: row-resize;
    }
    .playground-window-footer {
      flex-direction: column;
      gap: 0.5rem;
      align-items: flex-start;
    }
    .playground-dialect-selector {
      flex-wrap: wrap;
      gap: 0.5rem 1rem;
    }
    .playground-code-line {
      font-size: 0.75rem;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     AI WINDOW (Crono AI)
     ═══════════════════════════════════════════════════════════════ */

  .ai-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
    max-width: 420px;
    margin: 0 auto;
  }

  .ai-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, #8B5CF6 12%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .ai-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #8B5CF6;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
  }

  .ai-title {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-white);
    flex: 1;
  }

  .ai-provider {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    padding: 0.25rem 0.5rem;
    background: color-mix(in srgb, #8B5CF6 15%, transparent);
    border-radius: 999px;
  }

  .ai-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-height: 280px;
  }

  .ai-message {
    display: flex;
    gap: 0.625rem;
  }

  .ai-message.user {
    justify-content: flex-start;
  }

  .ai-message.user .ai-message-content {
    background: color-mix(in srgb, #8B5CF6 15%, transparent);
    border-radius: 0.75rem 0.75rem 0.75rem 0.25rem;
    padding: 0.625rem 0.875rem;
    font-size: 0.8125rem;
    color: var(--sl-color-white);
    max-width: 85%;
  }

  .ai-message.assistant {
    align-items: flex-start;
  }

  .ai-avatar-small {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: #8B5CF6;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .ai-message-card {
    flex: 1;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.75rem;
    padding: 0.75rem;
    font-size: 0.8125rem;
  }

  .ai-message-header {
    font-weight: 600;
    color: var(--sl-color-white);
    margin-bottom: 0.5rem;
    font-size: 0.8125rem;
  }

  .ai-table {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.625rem;
  }

  .ai-table-header,
  .ai-table-row {
    display: grid;
    grid-template-columns: 1fr 1fr 0.7fr;
    gap: 0.5rem;
    font-size: 0.75rem;
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
  }

  .ai-table-header {
    font-weight: 600;
    color: var(--sl-color-gray-2);
    background: color-mix(in srgb, var(--sl-color-hairline-light) 50%, transparent);
  }

  .ai-table-row {
    color: var(--sl-color-gray-1);
    background: color-mix(in srgb, var(--sl-color-bg-nav) 50%, transparent);
  }

  .ai-num {
    font-family: ui-monospace, monospace;
    color: var(--sl-color-white);
  }

  .ai-up {
    color: #22c55e;
    font-weight: 500;
  }

  .ai-actions {
    display: flex;
    gap: 0.75rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }

  .ai-action {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.6875rem;
    color: var(--sl-color-gray-3);
    cursor: pointer;
    transition: color 0.2s;
  }

  .ai-action:hover {
    color: #8B5CF6;
  }

  .ai-input-area {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .ai-input {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.625rem 0.75rem;
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 999px;
  }

  .ai-input-placeholder {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-4);
  }

  .ai-send {
    font-size: 0.75rem;
    font-weight: 600;
    color: white;
    background: #8B5CF6;
    border: none;
    border-radius: 0.5rem;
    padding: 0.375rem 0.75rem;
    cursor: pointer;
  }

  /* ═══════════════════════════════════════════════════════════════
     CRONO EXCEL MOCKUP
     ═══════════════════════════════════════════════════════════════ */
  .excel-window {
    background: var(--sl-color-bg);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -15px rgba(0,0,0,0.35), 0 0 0 1px rgba(255,255,255,0.04);
    font-size: 0.78rem;
  }
  .excel-titlebar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.75rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 90%, var(--sl-color-bg));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }
  .excel-logo { display: flex; align-items: center; }
  .excel-filename { flex: 1; font-size: 0.72rem; color: var(--sl-color-gray-3); font-weight: 500; }
  .excel-win-controls { display: flex; gap: 0; }
  .excel-btn {
    width: 32px; height: 22px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 0.65rem; color: var(--sl-color-gray-3);
    cursor: default;
    transition: background 0.15s;
  }
  .excel-btn:hover { background: color-mix(in srgb, var(--sl-color-gray-4) 15%, transparent); }
  .excel-btn.close:hover { background: #e81123; color: #fff; }
  .excel-ribbon {
    display: flex;
    gap: 0;
    padding: 0 0.5rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 60%, var(--sl-color-bg));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }
  .excel-tab {
    display: inline-flex; align-items: center; gap: 0.3rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.7rem; color: var(--sl-color-gray-3);
    border-bottom: 2px solid transparent;
    cursor: default;
  }
  .excel-tab.active { color: var(--sl-color-white); border-bottom-color: #1E7B47; }
  .excel-tab.crono-tab { color: #1E7B47; font-weight: 600; }
  .excel-formula-bar {
    display: flex; align-items: center; gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    background: var(--sl-color-bg);
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.7rem;
  }
  .excel-cell-ref { font-weight: 700; color: var(--sl-color-gray-2); min-width: 2rem; }
  .excel-fx { color: var(--sl-color-gray-4); font-style: italic; }
  .excel-formula { color: #1E7B47; font-family: monospace; font-size: 0.68rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .excel-grid { border-bottom: 1px solid var(--sl-color-hairline-light); }
  .excel-header-row, .excel-row {
    display: grid;
    grid-template-columns: 1.5rem repeat(4, 1fr);
  }
  .excel-col-header {
    padding: 0.2rem 0.4rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 70%, var(--sl-color-bg));
    border-right: 1px solid var(--sl-color-hairline-light);
    border-bottom: 1px solid var(--sl-color-hairline-light);
    text-align: center; font-size: 0.65rem; color: var(--sl-color-gray-3); font-weight: 600;
  }
  .excel-row-num {
    padding: 0.25rem 0.3rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 70%, var(--sl-color-bg));
    border-right: 1px solid var(--sl-color-hairline-light);
    border-bottom: 1px solid var(--sl-color-hairline-light);
    text-align: center; font-size: 0.65rem; color: var(--sl-color-gray-3);
  }
  .excel-cell {
    padding: 0.3rem 0.5rem;
    border-right: 1px solid var(--sl-color-hairline-light);
    border-bottom: 1px solid var(--sl-color-hairline-light);
    color: var(--sl-color-gray-2); font-size: 0.72rem;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .excel-cell.bold { font-weight: 700; color: var(--sl-color-white); }
  .excel-cell.positive { color: #1E7B47; font-weight: 600; }
  .excel-cell.crono-cell { background: color-mix(in srgb, #1E7B47 8%, var(--sl-color-bg)); }
  .excel-cell.crono-cell.selected {
    background: color-mix(in srgb, #1E7B47 15%, var(--sl-color-bg));
    outline: 2px solid #1E7B47; outline-offset: -2px;
  }
  .excel-row-header .excel-cell { background: color-mix(in srgb, var(--sl-color-bg-nav) 50%, var(--sl-color-bg)); }
  .excel-row-total .excel-cell { background: color-mix(in srgb, var(--sl-color-bg-nav) 40%, var(--sl-color-bg)); border-top: 2px solid var(--sl-color-hairline); }
  .excel-sheet-tabs {
    display: flex; align-items: center; gap: 0;
    padding: 0 0.5rem;
    background: color-mix(in srgb, var(--sl-color-bg-nav) 60%, var(--sl-color-bg));
    border-top: 1px solid var(--sl-color-hairline-light);
  }
  .excel-sheet {
    padding: 0.3rem 0.75rem;
    font-size: 0.68rem; color: var(--sl-color-gray-3);
    border-right: 1px solid var(--sl-color-hairline-light);
    cursor: default;
  }
  .excel-sheet.active { color: #1E7B47; font-weight: 600; background: var(--sl-color-bg); border-top: 2px solid #1E7B47; }

  .excel-quote {
    position: relative;
    margin: 1.25rem 0 1.5rem;
    padding: 0.25rem 1rem 0.25rem 2.75rem;
    font-size: 1.15rem;
    font-weight: 700;
    font-style: italic;
    color: var(--sl-color-white);
    line-height: 1.4;
    border: none;
    background: none;
  }
  .excel-quote::before {
    content: '\201C';
    position: absolute;
    left: 0;
    top: -0.3rem;
    font-size: 3.5rem;
    font-style: normal;
    color: #1E7B47;
    line-height: 1;
    font-family: Georgia, serif;
    opacity: 0.9;
  }
  .excel-quote::after {
    content: '\201D';
    font-size: 3.5rem;
    font-style: normal;
    color: #1E7B47;
    line-height: 0;
    vertical-align: -0.6rem;
    font-family: Georgia, serif;
    opacity: 0.9;
    margin-left: 0.15rem;
  }

  @media (max-width: 768px) {
    .excel-quote {
      font-size: 1rem;
      padding: 0.25rem 0.75rem;
      margin: 0.75rem 0 1rem;
      border-left: 3px solid #1E7B47;
    }
    .excel-quote::before,
    .excel-quote::after {
      display: none;
    }
  }

  /* ═══════════════════════════════════════════════════════════════
     SYNTAX HIGHLIGHTING - Single color for all reserved words
     ═══════════════════════════════════════════════════════════════ */

  .sql-keyword,
  .crono-keyword,
  .crono-special {
    color: #79c0ff;
    font-weight: 600;
  }

  .sql-identifier {
    color: #e6edf3;
  }

  /* ═══════════════════════════════════════════════════════════════
     DARK/LIGHT LOGO TOGGLE
     ═══════════════════════════════════════════════════════════════ */

  :root[data-theme='light'] .dark-logo { display: none; }
  :root[data-theme='dark'] .light-logo { display: none; }
  :root:not([data-theme='light']) .light-logo { display: none; }

  /* Make product labels brighter in dark mode */
  :root[data-theme='dark'] .product-label,
  html[data-theme='dark'] .product-label {
    filter: brightness(1.4);
    opacity: 1;
  }

  /* ═══════════════════════════════════════════════════════════════
     ECOSYSTEM DIAGRAM STYLES
     ═══════════════════════════════════════════════════════════════ */
  .ecosystem-diagram-wrapper {
    --bg: transparent;
    --ink: #1f2937;
    --muted: #6b7280;
    --border: #e5e7eb;
    --c-analysis: #C85A47;
    --c-excel: #1E7B47;
    --c-ai: #8B5CF6;
    --c-api: #0EA5E9;
    --c-other: #6B7280;
    --c-purple: #5B2C7D;
    --c-blue: #1B8AC7;
    --c-source: #0F766E;
    width: 100%;
  }
  
  .diagram {
    position: relative;
    aspect-ratio: 1320 / 620;
    width: 100%;
    max-height: 680px;
    min-height: 380px;
  }
  
  .diagram svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* nodes */
  .node circle.bg {
    fill: url(#nodeGradient);
    stroke: #fff;
    stroke-width: 2;
    filter: drop-shadow(0 8px 24px rgba(15, 23, 42, 0.12)) drop-shadow(0 2px 8px rgba(15, 23, 42, 0.08));
    transition: filter 0.3s ease;
  }

  .node:hover circle.bg {
    filter: drop-shadow(0 12px 32px rgba(15, 23, 42, 0.16)) drop-shadow(0 4px 12px rgba(15, 23, 42, 0.12));
  }
  
  .node text.title {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: .02em;
    fill: var(--ink);
    text-anchor: middle;
  }
  
  .node--source text.title {
    fill: var(--c-source);
  }
  
  .node--dwh text.title {
    fill: var(--c-source);
  }
  
  .node text.tag {
    font-size: 11px;
    letter-spacing: .06em;
    fill: var(--muted);
    text-anchor: middle;
    font-weight: 600;
  }
  
  .node .pill {
    fill: #fff;
    stroke: #e2e8f0;
    stroke-width: 1.5;
    filter: drop-shadow(0 2px 6px rgba(15, 23, 42, 0.08));
  }
  
  .node .pill-dot {
    fill: #3672C9;
  }
  
  .node--dwh .pill-dot {
    fill: var(--c-purple);
  }

  /* connector between source and DWH */
  .link-line {
    stroke: #3672C9;
    stroke-width: 1.6;
    fill: none;
    stroke-linecap: round;
  }
  
  .link-dot {
    fill: #3672C9;
  }

  /* the small tri-color arc inside the wheel */
  .inner-arc {
    fill: none;
    stroke-width: 4;
    stroke-linecap: round;
  }
  
  .inner-arc-dot {
    r: 4;
  }

  /* petals — rect with native rx for perfect rounded corners */
  .petal .shape {
    fill: url(#petalGradient);
    stroke: rgba(255,255,255,0.9);
    stroke-width: 1.5;
    filter: drop-shadow(0 12px 32px rgba(15,23,42,0.15)) drop-shadow(0 4px 10px rgba(15,23,42,0.09));
    transition: filter .35s ease;
  }
  
  .petal .icon-bg {
    transition: transform .35s cubic-bezier(.2,.8,.2,1), filter .35s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .petal {
    transition: transform .35s cubic-bezier(.2,.8,.2,1);
  }

  /* connector + label */
  .connector {
    stroke-width: 1.8;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke-width .25s ease;
  }
  
  .dot {
    transition: r .25s ease, transform .25s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .labels {
    position: absolute;
    inset: 0;
    list-style: none !important;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }
  
  li.label {
    position: absolute;
    left: 76.5%;
    transform: translateY(-50%);
    width: 23.5%;
    padding-left: 16px;
    pointer-events: auto;
    cursor: pointer;
    transition: transform .35s cubic-bezier(.2,.8,.2,1);
    list-style: none !important;
  }
  
  .label[data-key="analysis"] { top: 22%; }
  .label[data-key="excel"]    { top: 35%; }
  .label[data-key="ai"]       { top: 50%; }
  .label[data-key="api"]      { top: 65%; }
  .label[data-key="other"]    { top: 80%; }

  .label h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: .06em;
    color: var(--accent);
    transition: letter-spacing .3s ease;
    list-style: none !important;
  }
  
  .label ul {
    margin: 0;
    padding: 0;
    list-style: none !important;
  }
  
  .label li {
    list-style: none !important;
    position: relative;
    padding-left: 20px;
    font-size: 14px;
    color: #334155;
    line-height: 1.6;
    margin-bottom: 4px;
  }
  
  .label li:last-child {
    margin-bottom: 0;
  }
  
  .label li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%) rotate(-45deg);
    width: 10px;
    height: 6px;
    border-left: 2px solid var(--accent);
    border-bottom: 2px solid var(--accent);
    border-radius: 1px;
    opacity: .9;
    flex-shrink: 0;
  }
  
  .label[data-key="analysis"] { --accent: var(--c-analysis); }
  .label[data-key="excel"]    { --accent: var(--c-excel); }
  .label[data-key="ai"]       { --accent: var(--c-ai); }
  .label[data-key="api"]      { --accent: var(--c-api); }
  .label[data-key="other"]    { --accent: var(--c-other); }

  .label:hover {
    transform: translate(4px, -50%);
  }
  
  .label:hover h3 {
    letter-spacing: .08em;
  }


  /* ── Mobile diagram ── */
  .diagram-mobile { display: none; }

  @media (max-width: 768px) {
    .diagram { display: none; }
    .labels  { display: none; }
    .ecosystem-diagram-wrapper .diagram-controls { display: none !important; }

    .diagram-mobile {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      padding: 0 1rem 2rem;
      width: 100%;
    }

    /* ── Pipeline dark card ── */
    .dmo-pipeline {
      position: relative;
      overflow: hidden;
      border-radius: 1.375rem;
      background: #0D1117;
      border: 1px solid rgba(255,255,255,0.07);
      box-shadow:
        0 0 0 1px rgba(255,255,255,0.04),
        0 24px 48px -12px rgba(0,0,0,0.6),
        0 4px 16px rgba(0,0,0,0.3);
      padding: 0 0 0.25rem;
    }

    .dmo-glow-tr {
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(16,185,129,0.18) 0%, transparent 70%);
      pointer-events: none;
    }

    .dmo-glow-bl {
      position: absolute;
      bottom: -40px; left: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(15,118,110,0.2) 0%, transparent 70%);
      pointer-events: none;
    }

    /* Header bar */
    .dmo-pipe-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.625rem 1rem;
      border-bottom: 1px solid rgba(255,255,255,0.06);
      margin-bottom: 0.125rem;
    }

    .dmo-pipe-status {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.7rem;
      font-weight: 600;
      color: #10B981;
      letter-spacing: 0.03em;
    }

    .dmo-status-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #10B981;
      box-shadow: 0 0 6px #10B981;
      animation: dmo-pulse 2s ease-in-out infinite;
    }

    @keyframes dmo-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(0.85); }
    }

    .dmo-pipe-caption {
      font-size: 0.65rem;
      font-weight: 500;
      color: rgba(255,255,255,0.3);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }

    /* Nodes */
    .dmo-node {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 0.375rem 0.75rem;
      padding: 0.75rem 0.875rem;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 0.875rem;
      backdrop-filter: blur(4px);
    }

    .dmo-node-icon {
      width: 38px;
      height: 38px;
      border-radius: 0.625rem;
      background: rgba(var(--ni-rgb, 15,118,110), 0.12);
      border: 1px solid color-mix(in srgb, var(--ni) 30%, transparent);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      box-shadow: 0 0 12px color-mix(in srgb, var(--ni) 20%, transparent);
    }

    .dmo-node-body {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      flex: 1;
      min-width: 0;
    }

    .dmo-node-title {
      font-size: 0.8rem;
      font-weight: 700;
      color: rgba(255,255,255,0.92);
      letter-spacing: 0.02em;
    }

    .dmo-node-desc {
      font-size: 0.65rem;
      color: rgba(255,255,255,0.38);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .dmo-node-badge {
      font-size: 0.6rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      padding: 0.2rem 0.5rem;
      border-radius: 999px;
      border: 1px solid;
      flex-shrink: 0;
    }

    /* Petals */
    .dmo-petals {
      display: flex;
      justify-content: center;
      padding: 0.25rem 0 0.75rem;
      border-top: 1px solid rgba(255,255,255,0.05);
      margin-top: 0.25rem;
    }

    .dmo-petals svg {
      overflow: visible;
    }

    /* Connectors */
    .dmo-connector {
      display: flex;
      justify-content: center;
      padding: 0.125rem 0;
    }

    .dmo-conn-line {
      width: 2px;
      height: 36px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.06), rgba(54,114,201,0.5), rgba(255,255,255,0.06));
      border-radius: 1px;
      position: relative;
      overflow: visible;
    }

    .dmo-cdot {
      position: absolute;
      left: 50%;
      top: -4px;
      transform: translateX(-50%);
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #3B82F6;
      box-shadow: 0 0 6px #3B82F6;
      animation: dmo-fall 1.8s ease-in-out infinite;
    }

    @keyframes dmo-fall {
      0%   { top: -4px;    opacity: 0; }
      12%  { opacity: 1; }
      88%  { opacity: 1; }
      100% { top: calc(100% + 4px); opacity: 0; }
    }

    /* ETL section */
    .dmo-etl {
      margin: 0 0.75rem;
      padding: 0.75rem 0.875rem;
      background: rgba(54,114,201,0.08);
      border: 1px solid rgba(54,114,201,0.2);
      border-radius: 0.875rem;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
    }

    .dmo-etl-header {
      display: flex;
      align-items: center;
      gap: 0.375rem;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      color: #60A5FA;
    }

    .dmo-etl-tag {
      margin-left: auto;
      font-size: 0.6rem;
      font-weight: 500;
      color: rgba(96,165,250,0.6);
      letter-spacing: 0.03em;
    }

    .dmo-etl-row {
      display: flex;
      align-items: center;
      gap: 0;
    }

    .dmo-step {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
      flex: 1;
    }

    .dmo-step span {
      font-size: 0.58rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(255,255,255,0.35);
    }

    .dmo-step-ring {
      width: 30px;
      height: 30px;
      border-radius: 50%;
      border: 1.5px solid rgba(54,114,201,0.4);
      background: rgba(54,114,201,0.08);
      display: flex;
      align-items: center;
      justify-content: center;
      color: rgba(96,165,250,0.7);
    }

    .dmo-step--active .dmo-step-ring {
      border-color: #3B82F6;
      background: rgba(59,130,246,0.15);
      color: #60A5FA;
      box-shadow: 0 0 12px rgba(59,130,246,0.35);
      animation: dmo-ring-pulse 2s ease-in-out infinite;
    }

