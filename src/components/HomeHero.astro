              <div class="h-cell success"></div>
              <div class="h-cell warning"></div>
              <div class="h-cell success"></div>
              <div class="h-cell error"></div>
              <div class="h-cell success"></div>
              <div class="h-cell success"></div>
              <div class="h-cell success"></div>
              <div class="h-cell success"></div>
              <div class="h-cell running"></div>
              <div class="h-cell empty"></div>
              <div class="h-cell empty"></div>
            </div>
