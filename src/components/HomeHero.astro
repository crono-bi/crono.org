---
import { Code } from 'astro-expressive-code/components'

const products = [
  {
    id: 'sql',
    name: 'Crono SQL',
    tagline: 'Lenguaje SQL extendido',
    desc: '288 funciones, 50+ sentencias y sintaxis simplificada para construir data warehouses más rápido.',
    href: '/sql/',
    color: '#1B5F8C',
    stats: '376 docs',
    icon: '<path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>',
  },
  {
    id: 'metadata',
    name: 'Crono Metadata',
    tagline: 'Capa Semántica',
    desc: 'Crea el catálogo que traduce tu base de datos al lenguaje de negocio.',
    href: '/metadata/',
    color: '#5B2C7D',
    stats: '20 artículos',
    icon: '<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    id: 'analysis',
    name: 'Crono Analysis',
    tagline: 'Business Intelligence',
    desc: 'Análisis libre, dashboards e informes predefinidos para toda la organización.',
    href: '/analysis/',
    color: '#C85A47',
    stats: '17 artículos',
    icon: '<path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>',
  },
  {
    id: 'etl',
    name: 'Crono ETL',
    tagline: 'Data Warehouse',
    desc: 'Herramienta ETL diseñada para proyectos de carga de Data Warehouse.',
    href: '/etl/',
    color: '#1B8AC7',
    stats: 'En desarrollo',
    icon: '<circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>',
  },
]

const popularLinks = [
  { name: 'SELECT', href: '/sql/language/select/', desc: 'Consulta datos' },
  { name: 'MERGE', href: '/sql/language/merge/', desc: 'Sincroniza tablas' },
  { name: 'Funciones de fecha', href: '/sql/functions/', desc: '288 funciones disponibles' },
  { name: 'Vistas de metadatos', href: '/sql/views/', desc: 'Catálogo del sistema' },
]

const codeDemo = `SELECT 
    CustomerName,
    TotalSales = SUM(SalesAmount)
FROM Sales
WHERE Year = 2025
GROUP BY CustomerName
ORDER BY TotalSales DESC`
---

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- HERO SECTION -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="not-content relative overflow-hidden">
  <!-- Background with subtle gradient -->
  <div class="absolute inset-0 bg-[var(--sl-color-bg-nav)]"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-[var(--sl-color-bg)]"></div>
  
  <!-- Decorative orbs -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
  </div>

  <div class="relative mx-auto max-w-6xl px-6 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Copy -->
      <div class="text-center lg:text-left">
        <!-- Logo -->
        <div class="mb-8 flex justify-center lg:justify-start">
          <img src="/crono-logo-h-white.png" alt="Crono" class="h-16 w-auto dark-logo" />
          <img src="/crono-logo-h.png" alt="Crono" class="h-16 w-auto light-logo" />
        </div>
        
        <h1 class="hero-headline">
          La plataforma BI<br/>
          <span class="text-gradient">completa en español</span>
        </h1>
        
        <p class="hero-subhead mt-6">
          Documentación técnica oficial de Crono. Desde ETL hasta reporting, 
          una suite integrada para todo tu proyecto de datos.
        </p>
        
        <!-- CTA Buttons -->
        <div class="hero-ctas mt-8">
          <a href="/sql/" class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>
            </svg>
            Explorar Crono SQL
          </a>
          <a href="#productos" class="btn-secondary">
            Ver todos los manuales
          </a>
        </div>
        
        <!-- Stats -->
        <div class="hero-stats mt-10">
          <div class="stat">
            <span class="stat-value">400+</span>
            <span class="stat-label">páginas de docs</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">4</span>
            <span class="stat-label">productos</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat-value">ES</span>
            <span class="stat-label">en español</span>
          </div>
        </div>
      </div>
      
      <!-- Right: Code Demo -->
      <div class="code-window-wrapper">
        <div class="code-window">
          <div class="code-header">
            <div class="code-dots">
              <span></span><span></span><span></span>
            </div>
            <span class="code-title">ejemplo.cronosql</span>
          </div>
          <div class="code-body">
            <Code code={codeDemo} lang="sql" theme="starlight-dark" />
          </div>
        </div>
        
        <!-- Floating badges -->
        <div class="floating-badge badge-1">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Sintaxis simplificada</span>
        </div>
        <div class="floating-badge badge-2">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          <span>288 funciones</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- SEARCH SECTION -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="not-content relative border-y border-[var(--sl-color-hairline)] bg-[var(--sl-color-bg)]">
  <div class="mx-auto max-w-4xl px-6 py-8">
    <div class="flex flex-wrap items-center justify-center gap-4 text-sm text-[var(--sl-color-gray-2)]">
      <span class="font-medium text-[var(--sl-color-white)]">Popular:</span>
      {popularLinks.map((link, i) => (
        <>
          <a href={link.href} class="popular-link">
            <span class="popular-name">{link.name}</span>
            <span class="popular-desc">{link.desc}</span>
          </a>
          {i < popularLinks.length - 1 && <span class="text-[var(--sl-color-gray-5)]">·</span>}
        </>
      ))}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- BENTO GRID PRODUCTS -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section id="productos" class="not-content relative py-20 lg:py-28">
  <div class="mx-auto max-w-6xl px-6">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl lg:text-4xl font-bold text-[var(--sl-color-white)]">
        Elige tu manual
      </h2>
      <p class="mt-4 text-lg text-[var(--sl-color-gray-2)]">
        Cada producto tiene su documentación completa y ejemplos prácticos.
      </p>
    </div>
    
    <!-- Bento Grid -->
    <div class="bento-grid">
      <!-- SQL: Large card spanning 2 columns -->
      <a href="/sql/" class="bento-card bento-card-large group" style="--card-color: #1B5F8C;">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="card-icon" style="background: #1B5F8C20; color: #1B5F8C;">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/>
              </svg>
            </div>
            <span class="card-badge" style="background: #1B5F8C20; color: #1B5F8C;">376 docs</span>
          </div>
          <h3 class="card-title">Crono SQL</h3>
          <p class="card-desc">SQL con superpoderes. Sintaxis simplificada, 288 funciones integradas y compatibilidad con múltiples motores.</p>
          <div class="card-footer">
            <span class="card-cta">
              Explorar documentación
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
              </svg>
            </span>
          </div>
        </div>
        <div class="card-accent" style="background: linear-gradient(135deg, #1B5F8C, #2d7db5);"></div>
      </a>
      
      <!-- Metadata -->
      <a href="/metadata/" class="bento-card group" style="--card-color: #5B2C7D;">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="card-icon" style="background: #5B2C7D20; color: #5B2C7D;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>
              </svg>
            </div>
            <span class="card-badge" style="background: #5B2C7D20; color: #5B2C7D;">20 docs</span>
          </div>
          <h3 class="card-title">Crono Metadata</h3>
          <p class="card-desc">Capa semántica para traducir tu base de datos al lenguaje de negocio.</p>
        </div>
        <div class="card-accent" style="background: linear-gradient(135deg, #5B2C7D, #7B4F9D);"></div>
      </a>
      
      <!-- Analysis -->
      <a href="/analysis/" class="bento-card group" style="--card-color: #C85A47;">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="card-icon" style="background: #C85A4720; color: #C85A47;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 20V10"/><path d="M12 20V4"/><path d="M6 20v-6"/>
              </svg>
            </div>
            <span class="card-badge" style="background: #C85A4720; color: #C85A47;">17 docs</span>
          </div>
          <h3 class="card-title">Crono Analysis</h3>
          <p class="card-desc">Dashboards, informes y análisis para toda la organización.</p>
        </div>
        <div class="card-accent" style="background: linear-gradient(135deg, #C85A47, #D97A6A);"></div>
      </a>
      
      <!-- ETL -->
      <a href="/etl/" class="bento-card group" style="--card-color: #1B8AC7;">
        <div class="card-glow"></div>
        <div class="card-content">
          <div class="card-header">
            <div class="card-icon" style="background: #1B8AC720; color: #1B8AC7;">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/>
              </svg>
            </div>
            <span class="card-badge" style="background: #1B8AC720; color: #1B8AC7;">En desarrollo</span>
          </div>
          <h3 class="card-title">Crono ETL</h3>
          <p class="card-desc">Herramienta ETL especializada para proyectos de Data Warehouse.</p>
        </div>
        <div class="card-accent" style="background: linear-gradient(135deg, #1B8AC7, #3BAAD7);"></div>
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════ -->
<!-- FOOTER -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="not-content border-t border-[var(--sl-color-hairline)] py-12">
  <div class="mx-auto max-w-6xl px-6 flex flex-col items-center gap-4">
    <p class="text-sm text-[var(--sl-color-gray-3)]">
      Documentación oficial de Crono · Hecho con ❤️ en España
    </p>
  </div>
</section>

<style>
  /* ═══════════════════════════════════════════════════════════════
     HERO STYLES
     ═══════════════════════════════════════════════════════════════ */
  
  .hero-headline {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--sl-color-white);
  }
  
  .text-gradient {
    background: linear-gradient(135deg, var(--sl-color-accent), #22d3ee);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  
  .hero-subhead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    max-width: 480px;
  }
  
  .hero-ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  
  @media (min-width: 1024px) {
    .hero-ctas {
      justify-content: flex-start;
    }
    .hero-subhead {
      margin-left: 0;
      margin-right: 0;
    }
  }
  
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.875rem 1.75rem;
    background: var(--sl-color-accent);
    color: white;
    font-weight: 600;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 20px -4px var(--sl-color-accent);
  }
  
  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -6px var(--sl-color-accent);
    filter: brightness(1.1);
  }
  
  .btn-secondary {
    display: inline-flex;
    align-items: center;
    padding: 0.875rem 1.75rem;
    background: transparent;
    color: var(--sl-color-gray-1);
    font-weight: 500;
    border-radius: 0.75rem;
    text-decoration: none;
    border: 1px solid var(--sl-color-hairline-light);
    transition: all 0.2s ease;
  }
  
  .btn-secondary:hover {
    background: var(--sl-color-bg-nav);
    border-color: var(--sl-color-gray-3);
  }
  
  /* Stats */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  
  @media (min-width: 1024px) {
    .hero-stats {
      justify-content: flex-start;
    }
  }
  
  .stat {
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
  }
  
  .stat-value {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }
  
  .stat-label {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
  }
  
  .stat-divider {
    width: 1px;
    height: 1rem;
    background: var(--sl-color-hairline);
  }
  
  /* Orbs */
  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.08;
    animation: orb-float 20s ease-in-out infinite;
  }
  
  .orb-1 {
    width: 600px;
    height: 600px;
    background: var(--sl-color-accent);
    top: -20%;
    left: -10%;
  }
  
  .orb-2 {
    width: 400px;
    height: 400px;
    background: #22d3ee;
    bottom: -10%;
    right: 10%;
    animation-delay: -10s;
  }
  
  @keyframes orb-float {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(30px, -30px) scale(1.1); }
  }
  
  /* ═══════════════════════════════════════════════════════════════
     CODE WINDOW
     ═══════════════════════════════════════════════════════════════ */
  
  .code-window-wrapper {
    position: relative;
  }
  
  .code-window {
    background: #0d1117;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #30363d;
    box-shadow: 
      0 20px 50px -20px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(255, 255, 255, 0.05) inset;
  }
  
  .code-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.875rem 1.25rem;
    background: #161b22;
    border-bottom: 1px solid #30363d;
  }
  
  .code-dots {
    display: flex;
    gap: 0.5rem;
  }
  
  .code-dots span {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #ff5f56;
  }
  
  .code-dots span:nth-child(2) { background: #ffbd2e; }
  .code-dots span:nth-child(3) { background: #27c93f; }
  
  .code-title {
    font-size: 0.75rem;
    font-family: ui-monospace, monospace;
    color: #8b949e;
  }
  
  .code-body {
    padding: 1.25rem;
    font-size: 0.875rem;
    line-height: 1.6;
  }
  
  .code-body :global(pre) {
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
  }
  
  /* Floating badges */
  .floating-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-1);
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.3);
    animation: badge-float 6s ease-in-out infinite;
  }
  
  .badge-1 {
    top: 10%;
    right: -20px;
  }
  
  .badge-2 {
    bottom: 15%;
    left: -30px;
    animation-delay: -3s;
  }
  
  @keyframes badge-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }
  
  /* ═══════════════════════════════════════════════════════════════
     POPULAR LINKS
     ═══════════════════════════════════════════════════════════════ */
  
  .popular-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }
  
  .popular-link:hover {
    opacity: 0.8;
  }
  
  .popular-name {
    font-weight: 500;
    color: var(--sl-color-accent);
  }
  
  .popular-desc {
    color: var(--sl-color-gray-3);
  }
  
  /* ═══════════════════════════════════════════════════════════════
     BENTO GRID
     ═══════════════════════════════════════════════════════════════ */
  
  .bento-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  
  @media (min-width: 768px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      grid-template-rows: auto auto;
    }
    
    .bento-card-large {
      grid-column: span 2;
      grid-row: span 1;
    }
  }
  
  .bento-card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1.25rem;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.3s ease;
  }
  
  .bento-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-color);
    box-shadow: 0 20px 40px -15px rgba(0, 0, 0, 0.4);
  }
  
  .card-glow {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.3s ease;
    background: radial-gradient(600px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), 
      color-mix(in srgb, var(--card-color) 15%, transparent), 
      transparent 40%);
  }
  
  .bento-card:hover .card-glow {
    opacity: 1;
  }
  
  .card-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.75rem;
  }
  
  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  
  .card-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 0.875rem;
  }
  
  .card-badge {
    padding: 0.375rem 0.875rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
  }
  
  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--sl-color-white);
    margin: 0 0 0.5rem;
  }
  
  .card-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--sl-color-gray-2);
    margin: 0;
    flex: 1;
  }
  
  .card-footer {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--sl-color-hairline-light);
  }
  
  .card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-accent);
    transition: gap 0.2s ease;
  }
  
  .bento-card:hover .card-cta {
    gap: 0.75rem;
  }
  
  .card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  
  .bento-card:hover .card-accent {
    transform: scaleX(1);
  }
  
  /* Large card specific */
  .bento-card-large .card-content {
    padding: 2rem;
  }
  
  .bento-card-large .card-title {
    font-size: 1.5rem;
  }
  
  .bento-card-large .card-desc {
    font-size: 1rem;
    max-width: 400px;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     DARK/LIGHT LOGO TOGGLE
     ═══════════════════════════════════════════════════════════════ */
  
  :root[data-theme='light'] .dark-logo { display: none; }
  :root[data-theme='dark'] .light-logo { display: none; }
  :root:not([data-theme='light']) .light-logo { display: none; }
</style>

<script>
  // Mouse tracking for card glow effect
  document.querySelectorAll('.bento-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    });
  });
</script>
