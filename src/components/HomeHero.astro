<!-- CRONO ETL: Demo LEFT, Content RIGHT -->
<section id="crono-etl" class="not-content product-section scroll-reveal" style="--section-color: #1B8AC7;">
  <div class="section-bg" style="background: radial-gradient(ellipse 80% 60% at 30% 50%, color-mix(in srgb, #1B8AC7 8%, transparent), transparent);"></div>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Demo (Pipeline Visual) -->
      <div class="product-demo order-2 lg:order-1">
        <div class="pipeline-window">
          <div class="pipeline-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>
            <span>Pipeline: Carga Diaria DWH</span>
          </div>
          <div class="pipeline-body">
            <div class="pipeline-step done">
              <div class="step-icon">✓</div>
              <div class="step-info">
                <span class="step-name">Extracción ERP</span>
                <span class="step-time">02:30 AM · 4m 12s</span>
              </div>
            </div>
            <div class="pipeline-connector done"></div>
            <div class="pipeline-step done">
              <div class="step-icon">✓</div>
              <div class="step-info">
                <span class="step-name">Transformación</span>
                <span class="step-time">02:35 AM · 8m 45s</span>
              </div>
            </div>
            <div class="pipeline-connector done"></div>
            <div class="pipeline-step running">
              <div class="step-icon">◐</div>
              <div class="step-info">
                <span class="step-name">Carga DWH</span>
                <span class="step-time">En progreso...</span>
              </div>
            </div>
            <div class="pipeline-connector"></div>
            <div class="pipeline-step pending">
              <div class="step-icon">○</div>
              <div class="step-info">
                <span class="step-name">Validación</span>
                <span class="step-time">Pendiente</span>
              </div>
            </div>
          </div>
        </div>
        <div class="demo-badge" style="left: -15px; bottom: 30%;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#38bdf8" stroke-width="2"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
          <span>Scheduling automático</span>
        </div>
