  }
  
  .bento-card:hover .card-cta {
    gap: 0.75rem;
  }
  
  .card-accent {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    transform: scaleX(0);
    transition: transform 0.3s ease;
  }
  
  .bento-card:hover .card-accent {
    transform: scaleX(1);
  }
  
  /* Large card specific */
  .bento-card-large .card-content {
    padding: 2rem;
  }
  
  .bento-card-large .card-title {
    font-size: 1.5rem;
  }
  
  .bento-card-large .card-desc {
    font-size: 1rem;
    max-width: 400px;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     PRODUCT SECTIONS
     ═══════════════════════════════════════════════════════════════ */
  
  .product-section {
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--sl-color-hairline);
  }

  /* ═══════════════════════════════════════════════════════════════
     SCROLL REVEAL ANIMATIONS
     ═══════════════════════════════════════════════════════════════ */

  .scroll-reveal {
    opacity: 0;
    transform: translateY(60px);
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger children animation */
  .scroll-reveal .product-content {
    opacity: 0;
    transform: translateX(-30px);
    transition: all 0.6s ease-out 0.2s;
  }

  .scroll-reveal .product-demo {
    opacity: 0;
    transform: translateX(30px);
    transition: all 0.6s ease-out 0.3s;
  }

  .scroll-reveal.is-visible .product-content,
  .scroll-reveal.is-visible .product-demo {
    opacity: 1;
    transform: translateX(0);
  }

  /* Alternating sides */
  .scroll-reveal:nth-child(even) .product-content {
    transform: translateX(30px);
    transition-delay: 0.3s;
  }

  .scroll-reveal:nth-child(even) .product-demo {
    transform: translateX(-30px);
    transition-delay: 0.2s;
  }

  .scroll-reveal:nth-child(even).is-visible .product-content,
  .scroll-reveal:nth-child(even).is-visible .product-demo {
    transform: translateX(0);
  }

  .section-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  
  .product-content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .product-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    background: color-mix(in srgb, currentColor 12%, transparent);
    width: fit-content;
  }
  
  .product-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--sl-color-white);
    margin: 0;
  }
  
  .product-desc {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--sl-color-gray-2);
    margin: 0;
    max-width: 480px;
  }
  
  .product-features {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  
  .product-features li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
  }
  
  .btn-product {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    color: white;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    border: none;
    box-sizing: border-box;
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 4px 8px -2px rgba(0, 0, 0, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.15);
  }

  .btn-product:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      0 8px 16px -4px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .btn-product:active {
    transform: translateY(0);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.1),
      inset 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .btn-product-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    padding: 1rem 1.75rem;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.75rem;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    border: 1.5px solid currentColor;
    background: transparent;
    box-sizing: border-box;
    box-shadow: inset 0 0 0 transparent;
  }

  .btn-product-secondary:hover {
    transform: translateY(-1px);
    background: color-mix(in srgb, currentColor 8%, transparent);
    box-shadow:
      0 1px 2px rgba(0, 0, 0, 0.05),
      0 4px 8px -2px color-mix(in srgb, currentColor 15%, transparent);
  }

  .btn-product-secondary:active {
    transform: translateY(0);
    background: color-mix(in srgb, currentColor 12%, transparent);
  }

  /* Product Actions - Multiple buttons */
  .product-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.5rem;
  }

  .product-actions .btn-product,
  .product-actions .btn-product-secondary {
    margin-top: 0;
  }

  /* ═══════════════════════════════════════════════════════════════
     PLAYGROUND BRAND - Blue (#3B82F6)
     ═══════════════════════════════════════════════════════════════ */
  .btn-playground-secondary {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.5rem;
    color: #3B82F6;
    font-weight: 600;
    font-size: 0.9375rem;
    border-radius: 0.625rem;
    text-decoration: none;
    border: 2px solid #3B82F6;
    background: rgba(59, 130, 246, 0.08);
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    width: fit-content;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
  }

  .btn-playground-secondary::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.15) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .btn-playground-secondary:hover {
    transform: translateY(-2px) scale(1.02);
    background: #3B82F6;
    color: #fff;
    box-shadow: 
      0 4px 20px -4px rgba(59, 130, 246, 0.5),
      0 0 0 1px rgba(59, 130, 246, 0.3) inset;
  }

  .btn-playground-secondary:hover::before {
    opacity: 1;
  }

  .btn-playground-secondary svg {
    stroke: currentColor;
    transition: transform 0.2s ease;
  }

  .btn-playground-secondary:hover svg {
    transform: translateX(2px);
  }

  /* Code Window Playground Link - Yellow Ochre */
  .code-playground-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    color: #000;
    font-size: 0.8125rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.5rem;
    background: #3B82F6;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 
      0 2px 8px -2px rgba(59, 130, 246, 0.4),
      0 0 0 1px rgba(0, 0, 0, 0.1) inset;
    position: relative;
    overflow: hidden;
  }

  .code-playground-link::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .code-playground-link:hover {
    transform: translateY(-1px) scale(1.02);
    background: #60A5FA;
    box-shadow: 
      0 4px 16px -2px rgba(59, 130, 246, 0.5),
      0 0 0 1px rgba(0, 0, 0, 0.05) inset;
  }

  .code-playground-link:hover::before {
    opacity: 1;
  }

  .code-playground-link svg {
    stroke: #000;
    stroke-width: 2.5;
    transition: transform 0.2s ease;
  }

  .code-playground-link:hover svg {
    transform: translateX(1px);
  }
  
  /* Product Demo */
  .product-demo {
    position: relative;
  }
  
  .demo-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--sl-color-gray-1);
    box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.3);
    animation: demo-float 5s ease-in-out infinite;
  }
  
  @keyframes demo-float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  
  .demo-badge-1 {
    animation-delay: 0s;
  }
  
  .demo-badge-2 {
    animation-delay: -2.5s;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     CATALOG WINDOW (Metadata)
     ═══════════════════════════════════════════════════════════════ */
  
  .catalog-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
  }
  
  .catalog-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #5B2C7D 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--sl-color-white);
  }

  .catalog-header svg {
    color: #5B2C7D;
    order: 1;
  }

  .catalog-header::after {
    content: '— □ ×';
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
    order: 2;
  }
  
  .catalog-body {
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .catalog-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.875rem;
    border-radius: 0.5rem;
    font-size: 0.875rem;
    transition: background 0.2s;
  }
  
  .catalog-item:hover,
  .catalog-item.active {
    background: color-mix(in srgb, #5B2C7D 10%, transparent);
  }
  
  .catalog-icon {
    font-size: 1rem;
    opacity: 0.7;
  }
  
  .catalog-icon.dim { color: #5B2C7D; }
  .catalog-icon.fact { color: #C85A47; }
  .catalog-icon.ind { color: #1B5F8C; }
  
  .catalog-name {
    flex: 1;
    font-weight: 500;
    color: var(--sl-color-white);
  }
  
  .catalog-type {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg);
    padding: 0.25rem 0.625rem;
    border-radius: 0.25rem;
  }
  
  /* ═══════════════════════════════════════════════════════════════
     SWAGGER WINDOW (API)
     ═══════════════════════════════════════════════════════════════ */

  .swagger-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid color-mix(in srgb, #0EA5E9 25%, var(--sl-color-hairline-light));
    border-radius: 1rem;
    overflow: hidden;
    box-shadow:
      0 0 0 1px color-mix(in srgb, #0EA5E9 8%, transparent),
      0 20px 50px -15px rgba(0,0,0,0.5);
  }

  .swagger-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: color-mix(in srgb, #0EA5E9 12%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .swagger-title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .swagger-version {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #0EA5E9 20%, transparent);
    color: #0EA5E9;
    border: 1px solid color-mix(in srgb, #0EA5E9 30%, transparent);
  }

  .swagger-oas {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    background: color-mix(in srgb, #22c55e 15%, transparent);
    color: #22c55e;
    border: 1px solid color-mix(in srgb, #22c55e 30%, transparent);
    margin-left: auto;
  }

  .swagger-body {
    padding: 0.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .swagger-endpoint {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.5rem 0.75rem;
    border-radius: 0.5rem;
    border: 1px solid transparent;
    transition: background 0.15s ease;
    cursor: default;
  }

  .swagger-endpoint.get { border-color: color-mix(in srgb, #0EA5E9 20%, transparent); background: color-mix(in srgb, #0EA5E9 5%, transparent); }
  .swagger-endpoint.post { border-color: color-mix(in srgb, #22c55e 20%, transparent); background: color-mix(in srgb, #22c55e 5%, transparent); }
  .swagger-endpoint.delete { border-color: color-mix(in srgb, #ef4444 20%, transparent); background: color-mix(in srgb, #ef4444 5%, transparent); }

  .swagger-method {
    font-size: 0.65rem;
    font-weight: 800;
    font-family: monospace;
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    min-width: 36px;
    text-align: center;
    flex-shrink: 0;
  }

  .swagger-method.get { background: #0EA5E9; color: #fff; }
  .swagger-method.post { background: #22c55e; color: #fff; }
  .swagger-method.delete { background: #ef4444; color: #fff; }

  .swagger-path {
    font-family: monospace;
    font-size: 0.8rem;
    color: var(--sl-color-white);
    font-weight: 500;
    flex-shrink: 0;
  }

  .swagger-desc {
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .swagger-status {
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.4rem;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .swagger-status.s200 { background: color-mix(in srgb, #22c55e 20%, transparent); color: #22c55e; }
  .swagger-status.s204 { background: color-mix(in srgb, #0EA5E9 20%, transparent); color: #0EA5E9; }

  .swagger-endpoint-active {
    box-shadow: 0 0 0 1px color-mix(in srgb, #22c55e 40%, transparent);
  }

  /* ── API demo wrapper ── */
  .api-demo-wrap {
    position: relative;
    padding-bottom: 3rem;
  }

  /* ── Floating JSON response ── */
  .api-float-response {
    position: absolute;
    bottom: -0.5rem;
    right: -1rem;
    width: 230px;
    background: var(--sl-color-bg);
    border: 1px solid color-mix(in srgb, #22c55e 30%, var(--sl-color-hairline-light));
    border-radius: 0.625rem;
    overflow: hidden;
    box-shadow: 0 8px 24px -6px rgba(0,0,0,0.45);
    z-index: 2;
  }

  .api-float-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.4rem 0.625rem;
    background: color-mix(in srgb, #22c55e 10%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    font-size: 0.7rem;
  }

  .api-float-label {
    font-weight: 700;
    color: var(--sl-color-white);
  }

  .api-float-latency {
    color: #facc15;
    margin-left: auto;
  }

  .api-float-code.s200 {
    font-weight: 700;
    color: #22c55e;
    font-size: 0.65rem;
  }

  .api-float-body {
    margin: 0;
    padding: 0.5rem 0.625rem;
    font-size: 0.7rem;
    line-height: 1.6;
    font-family: monospace;
    background: transparent;
    white-space: pre;
    overflow: hidden;
  }

  .json-bracket { color: var(--sl-color-gray-2); }
  .json-brace   { color: var(--sl-color-gray-2); }
  .json-key     { color: #93c5fd; }
  .json-str     { color: #86efac; }
  .json-num     { color: #fda4af; }

  /* ── Floating sparkline chart ── */
  .api-float-chart {
    position: absolute;
    top: -1rem;
    right: -1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid color-mix(in srgb, #0EA5E9 25%, var(--sl-color-hairline-light));
    border-radius: 0.625rem;
    padding: 0.5rem 0.75rem;
    box-shadow: 0 4px 16px -4px rgba(0,0,0,0.4);
    z-index: 3;
    min-width: 110px;
  }

  .api-chart-label {
    font-size: 0.65rem;
    color: var(--sl-color-gray-3);
    margin-bottom: 0.35rem;
    white-space: nowrap;
  }

  .api-sparkline {
    display: flex;
    align-items: flex-end;
    gap: 2px;
    height: 28px;
    margin-bottom: 0.35rem;
  }

  .api-sparkline span {
    flex: 1;
    background: #0EA5E9;
    border-radius: 2px 2px 0 0;
    opacity: 0.85;
    min-height: 3px;
  }

  .api-sparkline span:last-child {
    opacity: 1;
    background: #38bdf8;
  }

  .api-chart-value {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--sl-color-white);
    line-height: 1;
  }

  .api-chart-value span {
    font-size: 0.65rem;
    font-weight: 400;
    color: var(--sl-color-gray-3);
  }

  /* ── Metric pills ── */
  .api-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .api-pill {
    font-size: 0.7rem;
    font-weight: 600;
    padding: 0.25rem 0.625rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .api-pill.green { background: color-mix(in srgb, #22c55e 12%, transparent); color: #22c55e; border-color: color-mix(in srgb, #22c55e 25%, transparent); }
  .api-pill.blue  { background: color-mix(in srgb, #0EA5E9 12%, transparent); color: #0EA5E9; border-color: color-mix(in srgb, #0EA5E9 25%, transparent); }
  .api-pill.purple{ background: color-mix(in srgb, #8B5CF6 12%, transparent); color: #8B5CF6; border-color: color-mix(in srgb, #8B5CF6 25%, transparent); }

  /* ═══════════════════════════════════════════════════════════════
     DASHBOARD WINDOW (Analysis)
     ═══════════════════════════════════════════════════════════════ */
  
  .dashboard-window {
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    border-radius: 1rem;
    overflow: hidden;
    box-shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.4);
  }
  
  .dashboard-header {
    padding: 0.5rem 1rem;
    background: color-mix(in srgb, #C85A47 15%, var(--sl-color-bg-nav));
    border-bottom: 1px solid var(--sl-color-hairline-light);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .dashboard-header::after {
    content: '— □ ×';
    font-size: 10px;
    letter-spacing: 4px;
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }

  .dashboard-tabs {
    display: flex;
    gap: 1rem;
  }
  
  .dashboard-tabs .tab {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    padding: 0.375rem 0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
  }
  
  .dashboard-tabs .tab.active {
    color: var(--sl-color-white);
    border-bottom-color: #C85A47;
  }
  
  .dashboard-body {
    padding: 1.5rem;
  }
  
  .chart-container {
    margin-bottom: 1.5rem;
  }
  
  .chart-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }
  
  .chart-bars {
    display: flex;
    align-items: flex-end;
    justify-content: space-around;
    gap: 0.75rem;
    height: 120px;
    padding: 0 0.5rem;
  }
  
  .chart-bars .bar {
    flex: 1;
    max-width: 40px;
    background: color-mix(in srgb, #C85A47 30%, var(--sl-color-gray-5));
    border-radius: 0.25rem 0.25rem 0 0;
    position: relative;
    transition: all 0.3s ease;
  }
  
  .chart-bars .bar.active {
    background: #C85A47;
  }
  
  .chart-bars .bar label {
    position: absolute;
    bottom: -1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6875rem;
