          <span>Ver Calendas</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="opacity: 0.7;"><path d="M7 17 17 7"/><path d="M7 7h10v10"/></svg>
        </a>
        <!-- Mini heatmap preview -->
        <div class="calendas-preview">
          <div class="heatmap-mini">
            <div class="heatmap-title">Dashboard Calendas</div>
            <div class="heatmap-grid">
