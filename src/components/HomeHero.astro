              </svg>
            </div>
            <div class="hero-stat-big">+</div>
            <div class="hero-stat-sub">FÁCIL</div>
          </div>
          <div class="hero-stat-divider"></div>
          <div class="hero-stat-item">
            <div class="hero-stat-icon-wrap" style="--stat-accent: #22C55E;">
