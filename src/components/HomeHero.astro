<script>
  // Hide scroll indicator on scroll
  const scrollIndicator = document.getElementById('scroll-indicator');
  if (scrollIndicator) {
    const hideIndicator = () => {
      if (window.scrollY > 60) {
        scrollIndicator.classList.add('hidden');
        window.removeEventListener('scroll', hideIndicator);
      }
    };
    window.addEventListener('scroll', hideIndicator, { passive: true });
  }

  // Mouse tracking for card glow effect
  document.querySelectorAll('.bento-card').forEach(card => {
    card.addEventListener('mousemove', (e) => {
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      card.style.setProperty('--mouse-x', `${x}px`);
      card.style.setProperty('--mouse-y', `${y}px`);
    });
  });

  // Scroll reveal animations using Intersection Observer
  const observerOptions = {
    root: null,
    rootMargin: '0px 0px -100px 0px',
    threshold: 0.15
  };

  const scrollObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('is-visible');
        scrollObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.scroll-reveal').forEach(el => {
    scrollObserver.observe(el);
  });
</script>

<script>
  import { gsap } from 'gsap';
  import { MotionPathPlugin } from 'gsap/MotionPathPlugin';
  gsap.registerPlugin(MotionPathPlugin);

  const INTRO_KEY = 'ecosystem-intro-done';

  // ── Trigger when ecosystem diagram enters viewport ──────────────
  const diagramWrapper = document.querySelector('.ecosystem-diagram-wrapper');
  let animationPaused = false;

  if (diagramWrapper) {
    const io = new IntersectionObserver(([e]) => {
      if (!e.isIntersecting) return;
      io.disconnect();
      if (sessionStorage.getItem(INTRO_KEY)) {
        // Intro already played this session: show everything instantly, run flows only
        revealAll();
        startAmbient();
        startFlow();
      } else {
        runEcosystemAnimation();
      }
    }, { threshold: 0.2, rootMargin: '-40px' });
    io.observe(diagramWrapper);

    // Animation toggle button
    const toggleBtn = document.getElementById('toggleAnimation');
    const ICON_PAUSE = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><rect x="3" y="2" width="3.5" height="12" rx="1"/><rect x="9.5" y="2" width="3.5" height="12" rx="1"/></svg>';
    const ICON_PLAY = '<svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M4 2.5l10 5.5-10 5.5V2.5z"/></svg>';

    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        animationPaused = !animationPaused;
        if (animationPaused) {
          gsap.globalTimeline.pause();
          toggleBtn.innerHTML = ICON_PLAY;
          toggleBtn.title = 'Reanudar animación';
        } else {
          gsap.globalTimeline.resume();
          toggleBtn.innerHTML = ICON_PAUSE;
          toggleBtn.title = 'Pausar animación';
        }
      });
    }

    // Fullscreen button
    const fullscreenBtn = document.getElementById('fullscreenBtn');
    const closeFullscreenBtn = document.getElementById('closeFullscreenBtn');

    if (fullscreenBtn) {
      fullscreenBtn.addEventListener('click', () => {
        if (!document.fullscreenElement) {
          diagramWrapper.requestFullscreen().catch(err => {
            console.warn('Error entering fullscreen:', err);
          });
        } else {
          document.exitFullscreen();
        }
      });
    }

    // Close fullscreen button
    if (closeFullscreenBtn) {
      closeFullscreenBtn.addEventListener('click', () => {
        if (document.fullscreenElement) {
          document.exitFullscreen();
        }
      });
    }

    // fullscreenchange: close button visibility handled by CSS :fullscreen selector
  }

  function revealAll() {
    const O = '590 360';
    document.querySelectorAll('.connector, .link-line').forEach(el => {
      gsap.set(el, { strokeDasharray: 0, strokeDashoffset: 0, autoAlpha: 1 });
    });
    gsap.set(['.node--dwh', '.petal'], { scale: 1, autoAlpha: 1, svgOrigin: O });
    gsap.set('.node--source',  { x: 0, autoAlpha: 1 });
    gsap.set('.link-dot',      { attr: { r: 4 }, autoAlpha: 1 });
    gsap.set('.dot',           { attr: { r: 5 } });
    gsap.set('.svg-label',     { x: 0, autoAlpha: 1 });
    gsap.set('.flow-dot',      { autoAlpha: 0 });
  }

  function runEcosystemAnimation() {
    const O = '590 360'; // DWH center in SVG coords (for svgOrigin)

    // ── 1. SETUP: force initial state via GSAP (overrides CSS) ──────
    gsap.set(['.node--dwh', '.petal'], { scale: 0, svgOrigin: O, autoAlpha: 0 });
    gsap.set('.node--source',          { x: -90, autoAlpha: 0 });
    gsap.set('.link-line',             { autoAlpha: 0 });
    gsap.set('.link-dot',              { attr: { r: 0 }, autoAlpha: 0 });
    gsap.set('.connector',             { autoAlpha: 0 });
    gsap.set('.dot',                   { attr: { r: 0 } });
    gsap.set('.svg-label',             { x: 35, autoAlpha: 0 });
    gsap.set('.dwh-ring',              { scale: 1, svgOrigin: O, autoAlpha: 0 });
    gsap.set('.flow-dot',              { autoAlpha: 0 });

    // Prepare connector + link-line stroke animation
    document.querySelectorAll('.connector, .link-line').forEach(el => {
      const len = el.getTotalLength();
      gsap.set(el, { strokeDasharray: len, strokeDashoffset: len });
    });

    // ── 2. INTRO TIMELINE ────────────────────────────────────────────
    const tl = gsap.timeline({
      defaults: { ease: 'power3.out' },
      onComplete: () => {
        sessionStorage.setItem(INTRO_KEY, '1');
        startAmbient();
        startFlow();
      }
    });

    tl
      // ① DWH awakening: three rings burst outward + fade
      .to('.dwh-ring', {
        scale: 2.8, autoAlpha: 0, svgOrigin: O,
        duration: 1.4, stagger: 0.28, ease: 'power2.out'
      })
      // ① (concurrent) DWH node zooms in with elastic bounce
      .to('.node--dwh', {
        scale: 1, autoAlpha: 1, svgOrigin: O,
        duration: 0.85, ease: 'back.out(2.2)'
      }, '<0.05')

      // ② Source node flies in from the left
      .to('.node--source', { x: 0, autoAlpha: 1, duration: 0.65 }, '-=0.55')

      // ③ Link line draws (source ↔ DWH)
      .to('.link-line', {
        strokeDashoffset: 0, autoAlpha: 1, duration: 0.55, ease: 'power2.inOut'
      }, '-=0.4')
      .to('.link-dot', {
        attr: { r: 4 }, autoAlpha: 1, duration: 0.3, stagger: 0.2, ease: 'back.out(3)'
      }, '-=0.15')

      // ④ Petals fan out from DWH center — the HERO moment
      .to('.petal', {
        scale: 1, autoAlpha: 1, svgOrigin: O,
        duration: 0.6, stagger: 0.1, ease: 'back.out(1.7)'
      }, '-=0.55')

      // ⑤ Connectors draw (synced with petal entrance)
      .to('.connector', {
        strokeDashoffset: 0, autoAlpha: 1,
        duration: 0.45, stagger: 0.1, ease: 'power2.inOut'
      }, '-=0.65')

      // ⑥ Connector endpoint dots pop
      .to('.dot', {
        attr: { r: 5 }, duration: 0.25, stagger: 0.09, ease: 'back.out(3)'
      }, '-=0.2')

      // ⑦ Labels slide in from right
      .to('.svg-label', {
        x: 0, autoAlpha: 1, duration: 0.5, stagger: 0.09
      }, '-=0.35');
  }

  // ── 3. AMBIENT: subtle looping micro-animations ──────────────────
  function startAmbient() {
    // DWH gentle breathing
    gsap.to('.node--dwh .bg', {
      attr: { r: 88 }, duration: 3, repeat: -1, yoyo: true, ease: 'sine.inOut'
    });

    // Each petal floats with a different phase (organic ecosystem feel)
    document.querySelectorAll('.petal').forEach((petal, i) => {
      gsap.to(petal, {
        y: i % 2 === 0 ? -4 : 4,
        duration: 2.6 + i * 0.4,
        repeat: -1, yoyo: true,
        ease: 'sine.inOut', delay: i * 0.5
      });
    });

    // Connector dots pulse softly
    gsap.to('.dot', {
      attr: { r: 7 }, opacity: 0.35,
      duration: 1.8, repeat: -1, yoyo: true,
      ease: 'sine.inOut', stagger: { each: 0.35 }
    });
  }

  // ── 4. FLOW: full data journey SOURCE → DWH → PETALS → LABELS ───
  function startFlow() {

    // ── A. SOURCE → DWH: particle travels along link-line ─────────
    // Animate cx/cy directly (more reliable than motionPath on <line>)
    const sourceParticle = document.querySelector('.source-particle');
    if (sourceParticle) {
      // link-line: x1=245 y1=360  x2=505 y2=360
      const shootSource = () => {
        gsap.timeline({ onComplete: () => gsap.delayedCall(1.8, shootSource) })
          .set(sourceParticle,   { attr: { cx: 245, cy: 360 }, autoAlpha: 0 })
          .to(sourceParticle,    { autoAlpha: 0.9, duration: 0.15 })
          .to(sourceParticle,    { attr: { cx: 505 }, duration: 1.1, ease: 'power1.inOut' }, '-=0.15')
          .to(sourceParticle,    { autoAlpha: 0, duration: 0.18 }, '-=0.2');
      };
      gsap.delayedCall(0.3, shootSource);
    }

    // ── B. DWH → PETALS: broadcast ring expands radially ──────────
    const broadcastRing = document.querySelector('.broadcast-ring');
    if (broadcastRing) {
      gsap.delayedCall(1.5, () => {
        gsap.timeline()
          .set(broadcastRing, { attr: { r: 90 }, opacity: 0.55 })
          .to(broadcastRing,  {
            attr: { r: 295 }, opacity: 0,
            duration: 1.3, ease: 'power2.out'
          });
      });
    }

    // ── C. PETALS → LABELS: particles along connectors ────────────
    const connectors = [...document.querySelectorAll('.connector')];
    const particles  = [...document.querySelectorAll('.flow-dot')];

    particles.forEach((dot, i) => {
      const path = connectors[i];
      if (!path) return;

      const shoot = () => {
        gsap.timeline({ onComplete: () => gsap.delayedCall(0.9, shoot) })
          .fromTo(dot, { autoAlpha: 0 }, { autoAlpha: 0.85, duration: 0.18 })
          .to(dot, {
            motionPath: { path, start: 0, end: 1 },
            duration: 1.7, ease: 'power1.inOut'
          }, '<')
          .to(dot, { autoAlpha: 0, duration: 0.22 }, '-=0.28');
      };

      // Stagger start so petals appear to "fire" after broadcast ring passes
      gsap.delayedCall(2.4 + i * 0.55, shoot);
    });
  }
</script>
