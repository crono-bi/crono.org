<!-- CRONO SQL: Content LEFT, Demo RIGHT -->
<section id="crono-sql" class="not-content product-section scroll-reveal" style="--section-color: #1B5F8C;">
  <div class="section-bg" style="background: radial-gradient(ellipse 80% 60% at 70% 50%, color-mix(in srgb, #1B5F8C 8%, transparent), transparent);"></div>
  <div class="mx-auto max-w-6xl px-6 py-16 lg:py-20">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left: Content -->
      <div class="product-demo">
        <div class="code-window">
          <div class="code-header">
            <span class="code-title">ventas.cronosql</span>
            <a href="/playground" class="code-playground-link" title="Abrir en Playground">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 17l6-6-6-6"/><path d="M12 19h8"/></svg>
              <span>Abrir en Playground</span>
            </a>
          </div>
          <div class="code-body">
            <pre class="code-block"><code><span class="sql-keyword">MERGE</span> <span class="crono-keyword">CLONE</span> <span class="sql-identifier">dwh.DimProducts</span>(<span class="sql-identifier">ProductSid</span>)
<span class="sql-keyword">SELECT</span>
  <span class="crono-special">#ProductID</span>,
  <span class="sql-identifier">Product.Name</span>        <span class="sql-identifier">Product</span>,
  <span class="sql-identifier">ProductCategory.name</span> <span class="sql-identifier">ProductCategory</span>,
  <span class="sql-identifier">ProductNumber</span>,
  <span class="sql-identifier">Color</span>,
  <span class="sql-identifier">StandardCost</span>,
  <span class="sql-identifier">ListPrice</span>
<span class="sql-keyword">FROM</span> <span class="sql-identifier">staging.Product</span>
<span class="sql-keyword">LEFT JOIN</span> <span class="sql-identifier">staging.ProductSubCategory</span>
  <span class="crono-keyword">USING</span> <span class="sql-identifier">Product</span>(<span class="sql-identifier">ProductSubcategoryID</span>)
<span class="sql-keyword">LEFT JOIN</span> <span class="sql-identifier">staging.ProductCategory</span>
  <span class="crono-keyword">USING</span> <span class="sql-identifier">ProductSubCategory</span>(<span class="sql-identifier">ProductCategoryId</span>)
<span class="crono-keyword">CHECK SNOWFLAKE</span></code></pre>
          </div>
        </div>
        <!-- Floating badges -->
        <div class="demo-badge demo-badge-1" style="right: -20px; top: 15%;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="2">
            <polyline points="20 6 9 17 4 12"/>
          </svg>
          <span>Sintaxis simplificada</span>
        </div>
        <div class="demo-badge demo-badge-2" style="left: -20px; bottom: 20%;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2">
            <path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/>
          </svg>
          <span>288 funciones</span>
        </div>
      </div>
      <!-- Right: Code Demo -->
      <div class="product-content">
        <div class="product-label" style="color: #1B5F8C;">Manual Principal · 376 artículos</div>
        <h2 class="product-title">Crono SQL</h2>
        <p class="product-desc">
          Desarrolla tu Data Warehouse en la mitad de tiempo. Crono SQL genera 
          automáticamente el código complejo que antes tardabas horas en escribir.
        </p>
        <ul class="product-features">
          <li><span style="color: #1B5F8C;">✓</span> Reduce el código manual un 70%</li>
          <li><span style="color: #1B5F8C;">✓</span> Auditoría automática en cada operación</li>
          <li><span style="color: #1B5F8C;">✓</span> Funciona con cualquier motor de base de datos</li>
          <li><span style="color: #1B5F8C;">✓</span> Detecta errores antes de ejecutar</li>
        </ul>
        <div class="product-actions">
          <a href="/sql/" class="btn-product" style="background: #1B5F8C; box-shadow: 0 4px 20px -4px #1B5F8C;">
            Explorar documentación
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="#playground" class="btn-product-secondary" style="color: #3B82F6;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
            Playground
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CRONO ETL: Demo LEFT, Content RIGHT -->
<section id="crono-etl" class="not-content product-section scroll-reveal" style="--section-color: #1B8AC7;">
  <div class="section-bg" style="background: radial-gradient(ellipse 80% 60% at 30% 50%, color-mix(in srgb, #1B8AC7 8%, transparent), transparent);"></div>
