<!-- ECOSISTEMA -->
<!-- ═══════════════════════════════════════════════════════════════ -->
<section class="ecosystem-section">
  <div class="ecosystem-container">
    <!-- Content above diagram -->
    <div class="ecosystem-header">
      <div class="ecosystem-header-label">
        <span class="ecosystem-header-icon">◆</span>
        MEJORES PRÁCTICAS
      </div>
      <h2 class="ecosystem-header-title">Una plataforma. <span class="ecosystem-header-accent">Todo el BI.</span></h2>
      <p class="ecosystem-header-desc">
        ETL, modelo semántico, análisis, reporting, dashboards e IA.
      </p>
    </div>

    <!-- Full width diagram -->
    <div class="ecosystem-diagram-wrapper">
      <div class="diagram">
      <svg viewBox="-60 60 1320 620" aria-hidden="true">
        <defs>
          <!-- Power BI icon -->
          <symbol id="i-powerbi" viewBox="0 0 64 64">
            <rect x="14" y="32" width="10" height="20" rx="1.5" fill="#F2C94C"/>
            <rect x="27" y="22" width="10" height="30" rx="1.5" fill="#F2A900"/>
            <rect x="40" y="12" width="10" height="40" rx="1.5" fill="#E08E0B"/>
          </symbol>

          <!-- Node gradient -->
          <radialGradient id="nodeGradient" cx="50%" cy="40%" r="60%">
            <stop offset="0%" stop-color="#ffffff"/>
            <stop offset="70%" stop-color="#f8fafc"/>
            <stop offset="100%" stop-color="#f1f5f9"/>
          </radialGradient>

          <!-- Petal gradient -->
          <linearGradient id="petalGradient" x1="50%" y1="0%" x2="50%" y2="100%">
            <stop offset="0%" stop-color="#ffffff"/>
            <stop offset="100%" stop-color="#f8fafc"/>
          </linearGradient>

          <!-- Server icon -->
          <symbol id="i-server" viewBox="0 0 64 64">
            <rect x="14" y="8" width="36" height="48" rx="4" fill="url(#serverGrad)" stroke="#0F766E" stroke-width="2"/>
            <rect x="18" y="16" width="28" height="6" rx="1" fill="#0F766E" opacity="0.3"/>
            <rect x="18" y="26" width="28" height="6" rx="1" fill="#0F766E" opacity="0.3"/>
            <rect x="18" y="36" width="28" height="6" rx="1" fill="#0F766E" opacity="0.3"/>
            <circle cx="24" cy="52" r="3" fill="#10B981"/>
            <circle cx="34" cy="52" r="2" fill="#6B7280"/>
            <linearGradient id="serverGrad" x1="0%" y1="0%" x2="0%" y2="100%">
              <stop offset="0%" stop-color="#CCFBF1"/>
              <stop offset="100%" stop-color="#99F6E4"/>
            </linearGradient>
          </symbol>

          <!-- Data Warehouse/Cube icon -->
          <symbol id="i-cube" viewBox="0 0 64 64">
            <path d="M32 8L54 20v24L32 56 10 44V20L32 8z" fill="url(#cubeGrad)" stroke="#0F766E" stroke-width="2"/>
            <path d="M32 8v24L10 44V20L32 8z" fill="#14B8A6" opacity="0.5"/>
            <path d="M32 32v24l22-12V20L32 32z" fill="#0D5C57" opacity="0.4"/>
            <path d="M10 20l22 12 22-12" stroke="#0F766E" stroke-width="1.5" fill="none"/>
            <linearGradient id="cubeGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#CCFBF1"/>
              <stop offset="50%" stop-color="#99F6E4"/>
              <stop offset="100%" stop-color="#5EEAD4"/>
            </linearGradient>
          </symbol>


          <!-- Analysis icon -->
          <symbol id="i-analysis" viewBox="0 0 64 64">
            <rect x="8" y="40" width="12" height="16" rx="2" fill="#C04A2D"/>
            <rect x="26" y="28" width="12" height="28" rx="2" fill="#C04A2D" opacity="0.7"/>
            <rect x="44" y="16" width="12" height="40" rx="2" fill="#C04A2D" opacity="0.5"/>
            <path d="M12 36l16-12 14 8 12-16" stroke="#C04A2D" stroke-width="3" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
          </symbol>

          <!-- Excel icon -->
          <symbol id="i-excel" viewBox="0 0 64 64">
            <rect x="10" y="8" width="44" height="48" rx="4" fill="#1E7B47" opacity="0.1" stroke="#1E7B47" stroke-width="2"/>
            <rect x="18" y="18" width="28" height="8" rx="1" fill="#1E7B47" opacity="0.3"/>
            <rect x="18" y="30" width="20" height="6" rx="1" fill="#1E7B47" opacity="0.3"/>
            <rect x="18" y="40" width="24" height="6" rx="1" fill="#1E7B47" opacity="0.3"/>
            <text x="40" y="52" font-size="14" font-weight="800" fill="#1E7B47">X</text>
          </symbol>

          <!-- AI icon - Robot face -->
          <symbol id="i-ai" viewBox="0 0 64 64">
            <rect x="14" y="12" width="36" height="40" rx="8" fill="#8B5CF6" opacity="0.15" stroke="#8B5CF6" stroke-width="2"/>
            <!-- Eyes -->
            <circle cx="24" cy="28" r="5" fill="#8B5CF6"/>
            <circle cx="40" cy="28" r="5" fill="#8B5CF6"/>
            <!-- Pupils -->
            <circle cx="24" cy="28" r="2" fill="white"/>
            <circle cx="40" cy="28" r="2" fill="white"/>
            <!-- Mouth -->
            <rect x="26" y="40" width="12" height="3" rx="1.5" fill="#8B5CF6"/>
            <!-- Antenna -->
            <line x1="32" y1="12" x2="32" y2="6" stroke="#8B5CF6" stroke-width="2" stroke-linecap="round"/>
            <circle cx="32" cy="4" r="3" fill="#8B5CF6"/>
          </symbol>

          <!-- Crono logo mark -->
          <symbol id="i-crono" viewBox="0 0 128 128">
            <path d="M84.25,15.44c-4.92,6.75-9.52,13.33-14.51,19.61-.83,1.04-3.41,1.24-5.06,1-16.4-2.37-31.31,6.13-36.18,20.8-4.27,12.85-.25,26.4,10.29,34.69,10.63,8.36,25.66,9.31,37.03,2.03,9.44-6.04,14.46-14.74,14.86-26.08.05-1.45,1-3.66,2.14-4.16,7.16-3.2,14.5-6.02,21.79-8.97,6.26,19.88-2.73,46.97-24.58,60.68-23.82,14.94-55.76,10.61-74.29-10.06C-3,84.09-4.05,53.49,13.22,31.56,29.41,11.01,62.27,3.39,84.25,15.44z"/>
            <path d="M61.05,63.5c2.8-3.84,5.58-7.68,8.4-11.5,10.6-14.36,21.2-28.72,31.83-43.06,4.34-5.86,5.59-5.83,9.72.3,5.23,7.78,10.3,15.68,15.61,23.4,2.15,3.13,2,4.97-1.76,6.52-19.85,8.15-39.64,16.45-59.48,24.64-1.12.46-2.43.49-3.65.72-.22-.34-.45-.68-.67-1.01z"/>
          </symbol>

          <!-- API icon - Gear with API text -->
          <symbol id="i-api" viewBox="0 0 64 64">
            <!-- Gear teeth -->
            <path d="M32 4l3 7h-6L32 4zM32 60l-3-7h6L32 60zM4 32l7-3v6L4 32zM60 32l-7 3v-6L60 32z" fill="#1B8AC7"/>
            <path d="M15 15l5 5-4 4-5-5L15 15zM49 49l-5-5 4-4 5 5L49 49zM15 49l5-5 4 4-5 5L15 49zM49 15l-5 5-4-4 5-5L49 15z" fill="#1B8AC7"/>
            <!-- Outer gear circle -->
            <circle cx="32" cy="32" r="20" fill="white" stroke="#1B8AC7" stroke-width="3"/>
            <!-- Inner circle -->
            <circle cx="32" cy="32" r="14" fill="#1B8AC7" opacity="0.1"/>
            <!-- API text -->
            <text x="32" y="36" font-size="14" font-weight="800" fill="#1B8AC7" text-anchor="middle">API</text>
          </symbol>
        </defs>

        <!-- LEFT NODE: FUENTES DE DATOS / CRONO ETL -->
        <g class="node node--source">
          <circle class="bg" cx="160" cy="360" r="85"/>
