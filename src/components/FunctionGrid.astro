---
import type { FuncExample } from './ManualLanding.astro'

interface Props {
  functions: FuncExample[]
}

const { functions } = Astro.props
---

<div class="functions-grid">
  {functions.map((fn) => (
    <div class="func-chip">
      <code>{fn.code}</code>
      <span>{fn.description}</span>
    </div>
  ))}
</div>

<style>
  .functions-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }

  @media (max-width: 768px) {
    .functions-grid {
      grid-template-columns: 1fr;
    }
  }

  .func-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
  }

  .func-chip code {
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 600;
    background: var(--sl-color-bg-inline-code);
    color: var(--brand-color, var(--sl-color-accent));
  }

  .func-chip span {
    color: var(--sl-color-gray-2);
  }
</style>
