---
// Ecosystem Diagram - Visual representation of Crono platform architecture
---

<section class="ecosystem-section">
  <div class="diagram-wrapper">
    <div class="diagram">
      <svg viewBox="0 0 1200 720" aria-hidden="true">
        <defs>
          <!-- Power BI icon -->
          <symbol id="i-powerbi" viewBox="0 0 64 64">
            <rect x="14" y="32" width="10" height="20" rx="1.5" fill="#F2C94C"/>
            <rect x="27" y="22" width="10" height="30" rx="1.5" fill="#F2A900"/>
            <rect x="40" y="12" width="10" height="40" rx="1.5" fill="#E08E0B"/>
          </symbol>
        </defs>

        <!-- LEFT NODE: FUENTES DE DATOS / CRONO ETL -->
        <g class="node node--source">
          <circle class="bg" cx="160" cy="360" r="118"/>
          <image href="/icons/ecosistema/source-server.png" x="110" y="278" width="100" height="100" preserveAspectRatio="xMidYMid meet"/>
          <text class="title" x="160" y="402">FUENTES DE DATOS</text>
          <line x1="120" y1="416" x2="200" y2="416" stroke="#e5e7eb" stroke-width="1"/>
          <!-- pill: CRONO ETL -->
          <g transform="translate(160,442)">
            <rect class="pill" x="-58" y="-14" width="116" height="28" rx="14"/>
            <image href="/icons/ecosistema/crono-etl.png" x="-54" y="-12" width="24" height="24" preserveAspectRatio="xMidYMid meet"/>
            <text class="tag" x="10" y="4">CRONO ETL</text>
          </g>
        </g>

        <!-- connector source -> dwh -->
        <line class="link-line" x1="278" y1="360" x2="402" y2="360"/>
        <circle class="link-dot" cx="278" cy="360" r="4"/>
        <circle class="link-dot" cx="402" cy="360" r="4"/>

        <!-- MIDDLE NODE: DATA WAREHOUSE / CRONO METADATA -->
        <g class="node node--dwh">
          <circle class="bg" cx="520" cy="360" r="118"/>
          <image href="/icons/ecosistema/dwh-cube.png" x="468" y="280" width="104" height="104" preserveAspectRatio="xMidYMid meet"/>
          <text class="title" x="520" y="402">DATA WAREHOUSE</text>
          <line x1="478" y1="416" x2="562" y2="416" stroke="#e5e7eb" stroke-width="1"/>
          <g transform="translate(520,442)">
            <rect class="pill" x="-78" y="-14" width="156" height="28" rx="14"/>
            <image href="/icons/ecosistema/crono-metadata.png" x="-74" y="-12" width="24" height="24" preserveAspectRatio="xMidYMid meet"/>
            <text class="tag" x="10" y="4">CRONO METADATA</text>
          </g>
        </g>

        <!-- inner tri-color arc decoration (radius 90 from wheel center 600,360) -->
        <g class="inner-deco">
          <!-- red top: angle -80° to -27° -->
          <path class="inner-arc" d="M615.6,271.3 A90,90 0 0 1 680.2,319.1" stroke="var(--c-analysis)"/>
          <!-- cyan middle: -27° to 27° -->
          <path class="inner-arc" d="M680.2,319.1 A90,90 0 0 1 680.2,400.9" stroke="var(--c-ai)"/>
          <!-- orange bottom: 27° to 80° -->
          <path class="inner-arc" d="M680.2,400.9 A90,90 0 0 1 615.6,448.7" stroke="var(--c-api)"/>
          <!-- endpoint dots -->
          <circle cx="615.6" cy="271.3" r="4" fill="var(--c-analysis)"/>
          <circle cx="615.6" cy="448.7" r="4" fill="var(--c-api)"/>
        </g>

        <!-- ===================== PETALS (wheel) ===================== -->
        <!-- Geometry: cx=600, cy=360, ri=95, ro=235, 5 petals -90..+90 -->

        <!-- Petal 0 — CRONO ANALYSIS (top) -->
        <g class="petal" data-key="analysis">
          <path class="shape" d="M602.0,265.0 L604.9,125.1 A235,235 0 0 1 734.1,167.0 L654.2,282.0 A95,95 0 0 0 602.0,265.0 Z"/>
          <g class="icon-bg">
            <image href="/icons/ecosistema/crono-analysis.png" x="623" y="175" width="56" height="56" preserveAspectRatio="xMidYMid meet"/>
          </g>
        </g>

        <!-- Petal 1 — CRONO EXCEL -->
        <g class="petal" data-key="excel">
          <path class="shape" d="M657.4,284.3 L742.1,172.8 A235,235 0 0 1 821.9,282.7 L689.7,328.8 A95,95 0 0 0 657.4,284.3 Z"/>
          <g class="icon-bg">
            <image href="/icons/ecosistema/crono-excel.png" x="706" y="235" width="56" height="56" preserveAspectRatio="xMidYMid meet"/>
          </g>
        </g>

        <!-- Petal 2 — CRONO AI -->
        <g class="petal" data-key="ai">
          <path class="shape" d="M690.9,332.5 L825.0,292.1 A235,235 0 0 1 825.0,427.9 L690.9,387.5 A95,95 0 0 0 690.9,332.5 Z"/>
          <g class="icon-bg">
            <image href="/icons/ecosistema/crono-ai.png" x="737" y="332" width="56" height="56" preserveAspectRatio="xMidYMid meet"/>
          </g>
        </g>

        <!-- Petal 3 — CRONO API -->
        <g class="petal" data-key="api">
          <path class="shape" d="M689.7,391.2 L821.9,437.3 A235,235 0 0 1 742.1,547.2 L657.4,435.7 A95,95 0 0 0 689.7,391.2 Z"/>
          <g class="icon-bg">
            <image href="/icons/ecosistema/crono-api.png" x="706" y="429" width="56" height="56" preserveAspectRatio="xMidYMid meet"/>
          </g>
        </g>

        <!-- Petal 4 — OTRAS SOLUCIONES (Power BI) -->
        <g class="petal" data-key="other">
          <path class="shape" d="M654.2,438.0 L734.1,553.0 A235,235 0 0 1 604.9,594.9 L602.0,455.0 A95,95 0 0 0 654.2,438.0 Z"/>
          <g class="icon-bg">
            <circle cx="651" cy="517" r="32" fill="#fff" stroke="#f1f1f4"/>
            <use href="#i-powerbi" x="619" y="485" width="64" height="64"/>
          </g>
        </g>

        <!-- ===================== connectors to labels ===================== -->
        <!-- each goes from petal outer edge (radial), kink, to label entry -->

        <!-- connectors end at x=918 (76.5% of 1200) to align with label left edge -->
        <g stroke-linecap="round" fill="none">
          <path class="connector" d="M735,167 L770,148 L918,148" stroke="var(--c-analysis)"/>
          <circle class="dot" cx="918" cy="148" r="5" fill="var(--c-analysis)" stroke="none"/>

          <path class="connector" d="M822,283 L860,252 L918,252" stroke="var(--c-excel)"/>
          <circle class="dot" cx="918" cy="252" r="5" fill="var(--c-excel)" stroke="none"/>

          <path class="connector" d="M835,360 L918,360" stroke="var(--c-ai)"/>
          <circle class="dot" cx="918" cy="360" r="5" fill="var(--c-ai)" stroke="none"/>

          <path class="connector" d="M822,437 L860,468 L918,468" stroke="var(--c-api)"/>
          <circle class="dot" cx="918" cy="468" r="5" fill="var(--c-api)" stroke="none"/>

          <path class="connector" d="M735,553 L770,572 L918,572" stroke="var(--c-other)"/>
          <circle class="dot" cx="918" cy="572" r="5" fill="var(--c-other)" stroke="none"/>
        </g>
      </svg>

      <!-- HTML LABELS (overlay) -->
      <ul class="labels">
        <li class="label" data-key="analysis">
          <h3>CRONO ANALYSIS</h3>
          <ul>
            <li>Análisis OLAP</li>
            <li>Análisis libre</li>
            <li>Dashboards de escritorio</li>
          </ul>
        </li>
        <li class="label" data-key="excel">
          <h3>CRONO EXCEL</h3>
          <ul>
            <li>Informes en Excel</li>
          </ul>
        </li>
        <li class="label" data-key="ai">
          <h3>CRONO AI</h3>
          <ul>
            <li>Lenguaje natural</li>
            <li>Text to SQL</li>
          </ul>
        </li>
        <li class="label" data-key="api">
          <h3>CRONO API</h3>
          <ul>
            <li>Servicios API REST</li>
            <li>Aplicaciones web a medida</li>
          </ul>
        </li>
        <li class="label" data-key="other">
          <h3>OTRAS SOLUCIONES</h3>
          <ul>
            <li>Microsoft Power BI</li>
            <li>Qlicksense</li>
          </ul>
        </li>
      </ul>
    </div>
  </div>
</section>

<style>
  .ecosystem-section {
    --bg: #f5f6f9;
    --ink: #1f2937;
    --muted: #6b7280;
    --border: #e5e7eb;
    --c-analysis: #C04A2D;
    --c-excel: #1E7B47;
    --c-ai: #3CA8B5;
    --c-api: #E5523F;
    --c-other: #1F7A4D;
    --c-purple: #7E3FA8;
    --c-blue: #3672C9;
    --c-source: #3672C9;
    
    background: var(--bg);
    padding: 0 32px 64px;
  }
  
  .diagram-wrapper {
    max-width: 1200px;
    margin: 0 auto;
  }
  
  .diagram {
    position: relative;
    aspect-ratio: 1200 / 720;
    width: 100%;
  }
  
  .diagram svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  /* nodes */
  .node circle.bg {
    fill: #fff;
    stroke: #eef0f4;
    stroke-width: 1;
  }
  
  .node text.title {
    font-size: 16px;
    font-weight: 700;
    letter-spacing: .04em;
    fill: var(--ink);
    text-anchor: middle;
  }
  
  .node--source text.title {
    fill: var(--c-source);
  }
  
  .node--dwh text.title {
    fill: var(--c-purple);
  }
  
  .node text.tag {
    font-size: 11px;
    letter-spacing: .06em;
    fill: var(--muted);
    text-anchor: middle;
    font-weight: 600;
  }
  
  .node .pill {
    fill: #fff;
    stroke: #eef0f4;
  }
  
  .node .pill-dot {
    fill: #3672C9;
  }
  
  .node--dwh .pill-dot {
    fill: var(--c-purple);
  }

  /* connector between source and DWH */
  .link-line {
    stroke: #3672C9;
    stroke-width: 1.6;
    fill: none;
    stroke-linecap: round;
  }
  
  .link-dot {
    fill: #3672C9;
  }

  /* the small tri-color arc inside the wheel */
  .inner-arc {
    fill: none;
    stroke-width: 2.4;
    stroke-linecap: round;
  }
  
  .inner-arc-dot {
    r: 4;
  }

  /* petals */
  .petal path.shape {
    fill: #ffffff;
    stroke: #eef0f4;
    stroke-width: 1;
    transition: transform .35s cubic-bezier(.2,.8,.2,1), filter .35s ease;
    transform-box: fill-box;
    transform-origin: center;
    filter: drop-shadow(0 6px 14px rgba(15, 23, 42, .06));
  }
  
  .petal {
    cursor: pointer;
  }
  
  .petal .icon-bg {
    transition: transform .35s cubic-bezier(.2,.8,.2,1), filter .35s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* hover: lift petal slightly outward + stronger shadow */
  .petal:hover path.shape {
    filter: drop-shadow(0 14px 28px rgba(15, 23, 42, .14));
  }
  
  .petal[data-key="analysis"]:hover { transform: translate(3px,-9px); }
  .petal[data-key="excel"]:hover    { transform: translate(8px,-6px); }
  .petal[data-key="ai"]:hover       { transform: translate(10px, 0); }
  .petal[data-key="api"]:hover      { transform: translate(8px, 6px); }
  .petal[data-key="other"]:hover    { transform: translate(3px, 9px); }
  
  .petal {
    transition: transform .35s cubic-bezier(.2,.8,.2,1);
  }
  
  .petal:hover .icon-bg {
    transform: scale(1.08);
  }

  /* connector + label */
  .connector {
    stroke-width: 1.4;
    fill: none;
    stroke-linecap: round;
    transition: stroke-width .25s ease;
  }
  
  .dot {
    transition: r .25s ease, transform .25s ease;
    transform-box: fill-box;
    transform-origin: center;
  }

  .labels {
    position: absolute;
    inset: 0;
    list-style: none;
    margin: 0;
    padding: 0;
    pointer-events: none;
  }
  
  .label {
    position: absolute;
    left: 76.5%;
    transform: translateY(-50%);
    width: 23.5%;
    padding-left: 16px;
    pointer-events: auto;
    cursor: pointer;
    transition: transform .35s cubic-bezier(.2,.8,.2,1);
  }
  
  .label[data-key="analysis"] { top: 22%; }
  .label[data-key="excel"]    { top: 35%; }
  .label[data-key="ai"]       { top: 50%; }
  .label[data-key="api"]      { top: 65%; }
  .label[data-key="other"]    { top: 80%; }

  .label h3 {
    margin: 0 0 8px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: .06em;
    color: var(--accent);
    transition: letter-spacing .3s ease;
  }
  
  .label ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  
  .label li {
    position: relative;
    padding-left: 22px;
    font-size: 14.5px;
    color: #334155;
    line-height: 1.55;
  }
  
  .label li::before {
    content: "";
    position: absolute;
    left: 0;
    top: .55em;
    width: 12px;
    height: 7px;
    border-left: 2px solid var(--accent);
    border-bottom: 2px solid var(--accent);
    transform: rotate(-45deg);
    border-radius: 1px;
    opacity: .85;
  }
  
  .label[data-key="analysis"] { --accent: var(--c-analysis); }
  .label[data-key="excel"]    { --accent: var(--c-excel); }
  .label[data-key="ai"]       { --accent: var(--c-ai); }
  .label[data-key="api"]      { --accent: var(--c-api); }
  .label[data-key="other"]    { --accent: var(--c-other); }

  .label:hover {
    transform: translate(4px, -50%);
  }
  
  .label:hover h3 {
    letter-spacing: .08em;
  }

  /* cross-hover sync: hovering a label brightens its petal, hovering a petal brightens its label */
  .diagram:has(.label[data-key="analysis"]:hover) .petal[data-key="analysis"] { transform: translate(3px,-9px); }
  .diagram:has(.label[data-key="excel"]:hover)    .petal[data-key="excel"]    { transform: translate(8px,-6px); }
  .diagram:has(.label[data-key="ai"]:hover)       .petal[data-key="ai"]       { transform: translate(10px, 0); }
  .diagram:has(.label[data-key="api"]:hover)      .petal[data-key="api"]      { transform: translate(8px, 6px); }
  .diagram:has(.label[data-key="other"]:hover)    .petal[data-key="other"]    { transform: translate(3px, 9px); }
  
  .diagram:has(.label[data-key="analysis"]:hover) .petal[data-key="analysis"] path.shape,
  .diagram:has(.label[data-key="excel"]:hover)    .petal[data-key="excel"]    path.shape,
  .diagram:has(.label[data-key="ai"]:hover)       .petal[data-key="ai"]       path.shape,
  .diagram:has(.label[data-key="api"]:hover)      .petal[data-key="api"]      path.shape,
  .diagram:has(.label[data-key="other"]:hover)    .petal[data-key="other"]    path.shape {
    filter: drop-shadow(0 14px 28px rgba(15, 23, 42, .14));
  }

  /* responsive: stack labels under diagram */
  @media (max-width: 820px) {
    .ecosystem-section {
      padding: 0 16px 32px;
    }
    
    .diagram {
      aspect-ratio: auto;
    }
    
    .diagram svg {
      position: relative;
      height: auto;
    }
    
    .labels {
      position: relative;
      display: grid;
      gap: 18px;
      margin-top: 24px;
    }
    
    .label {
      position: relative;
      left: auto;
      top: auto !important;
      transform: none;
      width: 100%;
    }
    
    .label:hover {
      transform: none;
    }
  }
</style>
