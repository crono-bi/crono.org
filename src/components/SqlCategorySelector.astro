---
import SectionIndex from './SectionIndex.astro'

interface Category {
  id: string
  title: string
  description: string
  icon: string
  count: number
  path: string
}

const categories: Category[] = [
  {
    id: 'language',
    title: 'Lenguaje Crono SQL',
    description: 'Guía completa de la sintaxis con ejemplos prácticos de cada sentencia.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>',
    count: 24,
    path: '/sql/language/'
  },
  {
    id: 'reference',
    title: 'Referencia del lenguaje',
    description: 'Documentación técnica detallada de sintaxis y funcionalidades avanzadas.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M12 11h5"/><path d="M12 7h5"/></svg>',
    count: 15,
    path: '/sql/reference/'
  },
  {
    id: 'functions',
    title: 'Funciones',
    description: 'Listado completo de funciones integradas agrupadas por categoría.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5h-2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><path d="m9 14 2 2 4-4"/></svg>',
    count: 40,
    path: '/sql/functions/'
  },
  {
    id: 'actions',
    title: 'Sentencias',
    description: 'Documentación de sentencias DML: MERGE, INSERT, UPDATE, DELETE.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>',
    count: 8,
    path: '/sql/actions/'
  },
  {
    id: 'views',
    title: 'Vistas',
    description: 'Vistas predefinidas del sistema para consultar metadatos.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>',
    count: 12,
    path: '/sql/views/'
  }
]
---

<div class="category-selector not-content">
  <!-- Category Cards -->
  <div class="categories-grid">
    {categories.map((cat) => (
      <button 
        class="category-card" 
        data-category={cat.id}
        onclick={`showCategory('${cat.id}', '${cat.title}')`}
      >
        <div class="category-header">
          <div class="category-icon" set:html={cat.icon} />
          <span class="category-count">{cat.count} artículos</span>
        </div>
        <h3 class="category-title">{cat.title}</h3>
        <p class="category-desc">{cat.description}</p>
        <div class="category-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </div>
      </button>
    ))}
  </div>

  <!-- Category Content Areas (pre-rendered, toggled via JS) -->
  <div id="category-content" class="category-content" style="display: none;">
    <div class="category-content-header">
      <h3 id="selected-title" class="selected-title"></h3>
      <button class="close-btn" onclick="closeCategory()">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
        </svg>
        Cerrar
      </button>
    </div>
    
    <!-- Pre-rendered SectionIndex for each category -->
    <div id="section-language" class="section-panel" style="display: none;">
      <SectionIndex src="/sql/language/" />
    </div>
    <div id="section-reference" class="section-panel" style="display: none;">
      <SectionIndex src="/sql/reference/" />
    </div>
    <div id="section-functions" class="section-panel" style="display: none;">
      <SectionIndex src="/sql/functions/" />
    </div>
    <div id="section-actions" class="section-panel" style="display: none;">
      <SectionIndex src="/sql/actions/" />
    </div>
    <div id="section-views" class="section-panel" style="display: none;">
      <SectionIndex src="/sql/views/" />
    </div>
  </div>
</div>

<script is:inline>
  function showCategory(categoryId, title) {
    // Update active card state
    document.querySelectorAll('.category-card').forEach(card => {
      card.classList.remove('active');
    });
    document.querySelector(`[data-category="${categoryId}"]`).classList.add('active');
    
    // Show content area
    const contentDiv = document.getElementById('category-content');
    contentDiv.style.display = 'block';
    
    // Update title
    document.getElementById('selected-title').textContent = title;
    
    // Hide all panels, show selected
    document.querySelectorAll('.section-panel').forEach(panel => {
      panel.style.display = 'none';
    });
    document.getElementById(`section-${categoryId}`).style.display = 'block';
    
    // Scroll to content
    contentDiv.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }
  
  function closeCategory() {
    document.getElementById('category-content').style.display = 'none';
    document.querySelectorAll('.category-card').forEach(card => {
      card.classList.remove('active');
    });
    document.querySelectorAll('.section-panel').forEach(panel => {
      panel.style.display = 'none';
    });
  }
</script>

<style>
  .category-selector {
    margin: 32px 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* For 5 items, last row centered */
  .categories-grid > *:nth-child(4) {
    grid-column: 1;
  }
  .categories-grid > *:nth-child(5) {
    grid-column: 2;
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
    .categories-grid > *:nth-child(4),
    .categories-grid > *:nth-child(5) {
      grid-column: auto;
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    border-radius: 12px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    text-align: left;
    cursor: pointer;
    transition: all 0.2s ease;
    width: 100%;
  }

  .category-card:hover,
  .category-card.active {
    transform: translateY(-2px);
    border-color: var(--sl-color-accent);
    box-shadow: 0 4px 20px rgba(27, 95, 140, 0.15);
  }

  .category-card.active {
    background: rgba(27, 95, 140, 0.1);
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(27, 95, 140, 0.15);
    color: var(--sl-color-accent);
  }

  .category-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .category-count {
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg-inline-code);
    padding: 4px 10px;
    border-radius: 20px;
  }

  .category-title {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--sl-color-white);
  }

  .category-desc {
    font-size: 13px;
    line-height: 1.5;
    margin: 0 0 16px;
    color: var(--sl-color-gray-2);
    flex: 1;
  }

  .category-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-3);
    transition: all 0.2s ease;
    margin-top: auto;
  }

  .category-card:hover .category-arrow,
  .category-card.active .category-arrow {
    background: var(--sl-color-accent);
    color: white;
  }

  /* Content Area */
  .category-content {
    margin-top: 32px;
    padding: 24px;
    border-radius: 12px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-accent);
  }

  .category-content-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .selected-title {
    font-size: 20px;
    font-weight: 700;
    margin: 0;
    color: var(--sl-color-white);
  }

  .close-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 16px;
    border-radius: 8px;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-2);
    border: 1px solid var(--sl-color-hairline-light);
    font-size: 13px;
    cursor: pointer;
    transition: all 0.15s ease;
  }

  .close-btn:hover {
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }

  .section-panel {
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
