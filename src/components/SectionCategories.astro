---
// Section Categories Component - Grouped navigation for large documentation
interface Category {
  id: string
  title: string
  description: string
  icon: string
  count: number
  href: string
}

interface Props {
  categories: Category[]
}

const { categories } = Astro.props
---

<div class="section-categories not-content">
  <div class="categories-grid">
    {categories.map((cat) => (
      <a href={cat.href} class="category-card">
        <div class="category-header">
          <div class="category-icon" set:html={cat.icon} />
          <span class="category-count">{cat.count} artículos</span>
        </div>
        <h3 class="category-title">{cat.title}</h3>
        <p class="category-desc">{cat.description}</p>
        <div class="category-arrow">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </div>
      </a>
    ))}
  </div>
</div>

<style>
  .section-categories {
    margin: 32px 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  /* For 5 items, center the last row */
  .categories-grid > *:nth-child(4) {
    grid-column: 1;
  }
  .categories-grid > *:nth-child(5) {
    grid-column: 2;
  }

  @media (max-width: 768px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
    .categories-grid > *:nth-child(4),
    .categories-grid > *:nth-child(5) {
      grid-column: auto;
    }
  }

  .category-card {
    display: flex;
    flex-direction: column;
    padding: 24px;
    border-radius: 12px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .category-card:hover {
    transform: translateY(-2px);
    border-color: var(--sl-color-accent);
    box-shadow: 0 4px 20px rgba(27, 95, 140, 0.15);
  }

  .category-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(27, 95, 140, 0.15);
    color: var(--sl-color-accent);
  }

  .category-icon :global(svg) {
    width: 20px;
    height: 20px;
  }

  .category-count {
    font-size: 11px;
    font-weight: 600;
    color: var(--sl-color-gray-3);
    background: var(--sl-color-bg-inline-code);
    padding: 4px 10px;
    border-radius: 20px;
  }

  .category-title {
    font-size: 17px;
    font-weight: 700;
    margin: 0 0 8px;
    color: var(--sl-color-white);
  }

  .category-desc {
    font-size: 13px;
    line-height: 1.5;
    margin: 0 0 16px;
    color: var(--sl-color-gray-2);
    flex: 1;
  }

  .category-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-3);
    transition: all 0.2s ease;
    margin-top: auto;
  }

  .category-card:hover .category-arrow {
    background: var(--sl-color-accent);
    color: white;
  }
</style>
