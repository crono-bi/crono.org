---
import { logos } from 'virtual:starlight/user-images';
import config from 'virtual:starlight/user-config';
const { siteTitleHref } = Astro.locals.starlightRoute;

const pathname = Astro.url.pathname;

let siteTitle = 'Manual de usuario';
if (pathname.startsWith('/analysis/')) {
	siteTitle = 'Manual Crono Analysis';
} else if (pathname.startsWith('/metadata/')) {
	siteTitle = 'Manual Crono Metadata';
} else if (pathname.startsWith('/etl/')) {
	siteTitle = 'Manual Crono ETL';
} else if (pathname.startsWith('/sql/')) {
	siteTitle = 'Manual Crono SQL';
}
---

<script is:inline define:vars={{ section: pathname.split('/')[1] }}>
  (function() {
    const brandClasses = ['brand-analysis', 'brand-metadata', 'brand-etl', 'brand-sql'];
    const html = document.documentElement;
    brandClasses.forEach(c => html.classList.remove(c));
    if (['analysis', 'metadata', 'etl', 'sql'].includes(section)) {
      html.classList.add('brand-' + section);
    }
  })();
</script>

<a href={siteTitleHref} class="site-title sl-flex">
	<!-- Crono Logo -->
	<img
		src="/crono-logo-h-white.png"
		alt="Crono"
		class="h-8 w-auto dark-logo"
	/>
	<img
		src="/crono-logo-h.png"
		alt="Crono"
		class="h-8 w-auto light-logo"
	/>
	<span class="sr-only" translate="no">
		{siteTitle}
	</span>
</a>

<style>
	@layer starlight.core {
		.site-title {
			align-items: center;
			gap: var(--sl-nav-gap);
			font-size: var(--sl-text-h4);
			font-weight: 600;
			color: var(--sl-color-text-accent);
			text-decoration: none;
			white-space: nowrap;
			min-width: 0;
		}
		span {
			overflow: hidden;
		}
		img {
			height: calc(var(--sl-nav-height) - 2 * var(--sl-nav-pad-y));
			width: auto;
			max-width: 100%;
			object-fit: contain;
			object-position: 0 50%;
		}
		/* Crono logo dark/light toggle */
		.dark-logo, .light-logo {
			height: 32px;
			width: auto;
		}
		:root[data-theme='light'] .dark-logo  { display: none; }
		:root[data-theme='dark']  .light-logo { display: none; }
		:root:not([data-theme='light']) .light-logo { display: none; }
	}
</style>
