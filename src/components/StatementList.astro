---
import type { Statement } from './ManualLanding.astro'

interface Props {
  statements: Statement[]
}

const { statements } = Astro.props
---

<div class="statements-list">
  {statements.map((stmt) => (
    <div class="statement-item">
      <strong>{stmt.name}</strong>
      <span>{stmt.description}</span>
    </div>
  ))}
</div>

<style>
  .statements-list {
    display: grid;
    gap: 0;
  }

  .statement-item {
    display: flex;
    gap: 16px;
    padding: 12px 0;
    font-size: 14px;
    line-height: 1.5;
    border-bottom: 1px solid var(--sl-color-hairline-light);
  }

  .statement-item:last-child {
    border-bottom: none;
  }

  .statement-item strong {
    min-width: 170px;
    font-size: 13px;
    font-family: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
    color: var(--brand-color, var(--sl-color-accent));
    font-weight: 600;
  }

  .statement-item span {
    color: var(--sl-color-gray-2);
  }

  @media (max-width: 768px) {
    .statement-item {
      flex-direction: column;
      gap: 4px;
    }
    .statement-item strong {
      min-width: auto;
    }
  }
</style>
