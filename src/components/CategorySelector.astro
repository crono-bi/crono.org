---
import type { Category } from './ManualLanding.astro'

interface Props {
  categories: Category[]
}

const { categories } = Astro.props
---

<div class="category-selector not-content">
  <div class="categories-grid">
    {categories.map((cat) => (
      <a href={cat.path} class="category-card">
        <div class="category-header">
          <div class="category-icon" set:html={cat.icon} />
          <div class="category-header-text">
            <h3 class="category-title">{cat.title}</h3>
            <span class="category-count">{cat.count} artículos</span>
          </div>
          <span class="category-cta">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </span>
        </div>
        <p class="category-desc">{cat.description}</p>
      </a>
    ))}
  </div>
</div>

<style>
  .category-selector {
    margin: 32px 0;
  }

  .categories-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 12px;
  }

  @media (max-width: 540px) {
    .categories-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Card */
  .category-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px 18px;
    border-radius: 12px;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline-light);
    text-align: left;
    cursor: pointer;
    transition: transform 0.2s cubic-bezier(.4,0,.2,1),
                box-shadow 0.2s cubic-bezier(.4,0,.2,1),
                border-color 0.2s ease;
    width: 100%;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }

  .category-card:hover {
    transform: translateY(-2px);
    border-color: var(--brand-color, var(--sl-color-accent));
    box-shadow:
      0 4px 16px rgba(var(--brand-rgb-value, 27, 95, 140), 0.10),
      0 1px 4px rgba(0,0,0,0.04);
  }

  /* Header row: icon + text + arrow */
  .category-header {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .category-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    min-width: 38px;
    border-radius: 10px;
    background: rgba(var(--brand-rgb-value, 27, 95, 140), 0.1);
    color: var(--brand-color, var(--sl-color-accent));
    transition: background 0.2s ease;
  }

  .category-card:hover .category-icon {
    background: rgba(var(--brand-rgb-value, 27, 95, 140), 0.18);
  }

  .category-icon :global(svg) {
    width: 18px;
    height: 18px;
  }

  .category-header-text {
    flex: 1;
    min-width: 0;
  }

  .category-title {
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    color: var(--sl-color-white);
    line-height: 1.3;
  }

  .category-count {
    font-size: 11px;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    line-height: 1.3;
  }

  /* Arrow CTA */
  .category-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    min-width: 30px;
    border-radius: 8px;
    background: var(--sl-color-bg-sidebar);
    color: var(--sl-color-gray-3);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
  }

  .category-card:hover .category-cta {
    background: var(--brand-color, var(--sl-color-accent));
    color: white;
    transform: translateX(2px);
  }

  /* Description */
  .category-desc {
    font-size: 12px;
    line-height: 1.5;
    margin: 0;
    color: var(--sl-color-gray-3);
    padding-left: 50px;
  }
</style>
