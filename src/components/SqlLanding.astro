---
// SQL Landing Page - Using the generic ManualLanding component
import ManualLanding from './ManualLanding.astro'
import type { Feature, Category, Statement, FuncExample } from './ManualLanding.astro'

const features: Feature[] = [
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>',
    title: 'SQL con superpoderes',
    description: 'Un lenguaje como SQL, pero más fácil de escribir, más mantenible y más escalable.'
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>',
    title: 'Generador de SQL',
    description: 'No es una base de datos ni una caja negra. Crono SQL genera código SQL nativo para tu motor.'
  },
  {
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5V19A9 3 0 0 0 21 19V5"/><path d="M3 12A9 3 0 0 0 21 12"/></svg>',
    title: 'Crono ETL',
    description: 'El lenguaje utilizado por Crono ETL para crear procesos de carga de Data Warehouse.'
  }
]

const categories: Category[] = [
  {
    id: 'language',
    title: 'Lenguaje Crono SQL',
    description: 'Guía completa de la sintaxis con ejemplos prácticos de cada sentencia.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 16 4-4-4-4"/><path d="m6 8-4 4 4 4"/><path d="m14.5 4-5 16"/></svg>',
    count: 24,
    path: '/sql/language/'
  },
  {
    id: 'reference',
    title: 'Referencia del lenguaje',
    description: 'Documentación técnica detallada de sintaxis y funcionalidades avanzadas.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/><path d="M12 11h5"/><path d="M12 7h5"/></svg>',
    count: 15,
    path: '/sql/reference/'
  },
  {
    id: 'functions',
    title: 'Funciones',
    description: 'Listado completo de funciones integradas agrupadas por categoría.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5h-2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><path d="m9 14 2 2 4-4"/></svg>',
    count: 40,
    path: '/sql/functions/'
  },
  {
    id: 'views',
    title: 'Vistas',
    description: 'Vistas predefinidas del sistema para consultar metadatos.',
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0z"/><path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>',
    count: 12,
    path: '/sql/views/'
  }
]

const engines = ['SQL Server', 'Snowflake', 'PostgreSQL', 'Redshift', 'BigQuery']

const statements: Statement[] = [
  { name: 'SELECT', description: 'Consultas con JOINs simplificados usando USING' },
  { name: 'MERGE UPSERT', description: 'Inserta nuevos registros y actualiza los existentes' },
  { name: 'MERGE HISTORY', description: 'Mantiene historial de cambios (SCD Tipo 2)' },
  { name: 'MERGE CLONE', description: 'Sincroniza completamente la tabla destino' },
  { name: 'DELETE AND INSERT', description: 'Recarga parcial: elimina y vuelve a insertar' },
  { name: 'CHECK SNOWFLAKE', description: 'Verifica que los JOINs no pierdan ni dupliquen registros' },
  { name: 'CALCULATE', description: 'Agregaciones sobre el resultado total con columnas agrupadas' },
  { name: 'MATERIALIZE', description: 'Tablas temporales para mejorar el rendimiento' }
]

const functions: FuncExample[] = [
  { code: 'margin(a, b)', description: 'Margen de ventas seguro' },
  { code: 'markup(a, b)', description: 'Márkup seguro' },
  { code: 'divide(a, b)', description: 'División segura (sin error /0)' },
  { code: 'substraction(a, b)', description: 'Resta segura' }
]

const codeExample = `SELECT
  Product.Name Product,
  ProductCategory.name ProductCategory,
  sum(SalesOrderDetail.LineTotal) Sales
FROM staging.SalesOrderDetail
INNER JOIN staging.Product USING ProductId
LEFT JOIN staging.ProductSubCategory USING ProductSubcategoryID
LEFT JOIN staging.ProductCategory USING ProductSubCategory(ProductCategoryId)`
---

<ManualLanding
  logo="/logos/Crono SQL.webp"
  logoAlt="Crono SQL"
  subtitle="SQL con superpoderes para construir Data Warehouses"
  ctaText="Acceder al manual"
  ctaHref="/sql/intro/"
  brandColor="#1B5F8C"
  features={features}
  featuresTitle="¿Qué es Crono SQL?"
  engines={engines}
  codeExample={{
    label: 'Crono SQL',
    code: codeExample
  }}
  statements={statements}
  statementsTitle="Sentencias principales"
  functions={functions}
  functionsTitle="Funciones integradas"
  functionsDesc="Crono SQL soporta todas las funciones nativas de cada motor y añade sus propias funciones como:"
  playgroundCta={{
    title: 'Playground interactivo',
    description: 'Escribe Crono SQL y mira en tiempo real el SQL generado para cada motor de base de datos.',
    buttonText: 'Abrir Playground',
    href: '/playground'
  }}
  categories={categories}
  categoriesTitle="Explorar por categoría"
  footerTitle="¿Listo para probar Crono SQL?"
  footerDesc="Explora la documentación completa y empieza a construir tu Data Warehouse."
  footerCta="Empezar ahora"
/>
