---
import LucideIcon from './LucideIcon.vue'

interface Card {
  icon: string
  title: string
  desc: string
}

interface Props {
  title?: string
  cards: Card[]
}

const { title, cards } = Astro.props as Props
---

{title && <h2>{title}</h2>}
<div class="not-content grid grid-cols-1 sm:grid-cols-3 gap-4 my-6">
  {cards.map((card) => (
    <div class="flex flex-col gap-3 p-6 rounded-xl border border-[var(--sl-color-hairline-light)] bg-[var(--sl-color-bg-nav)] hover:-translate-y-0.5 hover:shadow-md transition-all duration-150">
      <div class="text-[var(--sl-color-accent)]">
        <LucideIcon name={card.icon} size={24} client:load />
      </div>
      <p class="text-sm font-bold text-[var(--sl-color-white)] m-0!">{card.title}</p>
      <p class="text-xs leading-relaxed text-[var(--sl-color-gray-2)] m-0! opacity-90">{card.desc}</p>
    </div>
  ))}
</div>
