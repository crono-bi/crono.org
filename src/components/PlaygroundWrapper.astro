---
// Wrapper component for the Playground page
// Injects global styles to remove Starlight's default header and padding
---

<div class="pg-content">
  <slot />
</div>

<style is:global>
  /* ── Import Playground CSS (global, not scoped) ── */
  @import '../styles/playground-codemirror.css';
  @import '../styles/playground-editor.css';

  /* ── Hide Starlight footer in playground ── */
  body:has(.pg-content) footer {
    display: none !important;
  }

  /* ── Apply playground brand color (blue) + zero out main padding ── */
  body:has(.pg-content) {
    --sl-color-accent: #3B82F6;
    --sl-color-accent-low: #2563EB;
    --sl-color-accent-high: #60A5FA;
    --sl-color-text-accent: #3B82F6;
    --sl-main-pad: 0px;
  }

  /* ── Remove content-panel padding (green space) ── */
  body:has(.pg-content) .content-panel {
    padding: 0 !important;
    margin: 0 !important;
    max-width: 100% !important;
    width: 100% !important;
  }

  /* ── Remove Starlight max-width constraints ── */
  body:has(.pg-content) .sl-container,
  body:has(.pg-content) .sl-markdown-content {
    max-width: 100% !important;
    width: 100% !important;
    padding-inline: 0 !important;
  }

  /* ── Force full width on main content area ── */
  body:has(.pg-content) main,
  body:has(.pg-content) .main-frame,
  body:has(.pg-content) .main-pane,
  body:has(.pg-content) article,
  body:has(.pg-content) .lg\\:sl-flex {
    max-width: 100% !important;
    width: 100% !important;
    flex: 1 1 auto !important;
    padding: 0 !important;
  }

  /* ── Override Starlight's two-column layout flex constraints ── */
  body:has(.pg-content) .page {
    width: 100% !important;
    max-width: 100% !important;
  }

  body:has(.pg-content) .sidebar {
    flex-shrink: 0 !important;
  }

  /* ── Ensure the content panel doesn't constrain width ── */
  body:has(.pg-content) .content {
    width: 100% !important;
    max-width: 100% !important;
    min-width: 0 !important;
  }

  /* ── pg-content fills available height ── */
  .pg-content {
    height: calc(100vh - var(--sl-nav-height, 3.5rem) - 1.5rem);
    min-height: 500px;
    width: 100%;
    max-width: 100%;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .pg-content {
      height: auto;
      min-height: calc(100vh - var(--sl-nav-height, 3.5rem));
      overflow-y: auto;
    }
  }

  /* ── astro-island must also stretch ── */
  .pg-content > astro-island,
  .pg-content > astro-island > div {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    height: 100%;
    width: 100%;
    max-width: 100%;
  }

  @media (max-width: 1024px) {
    .pg-content > astro-island,
    .pg-content > astro-island > div {
      height: auto;
      min-height: 0;
      overflow: visible;
    }
  }
</style>
