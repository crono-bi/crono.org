---
// Wrapper component for the Playground page
// Injects global styles to remove Starlight's default header and padding
---

<div class="pg-content">
  <slot />
</div>

<style is:global>
  /* ── Apply playground brand color (yellow/ochre) ── */
  body:has(.pg-content) {
    --sl-color-accent: #D4A84B;
    --sl-color-accent-low: #D4A84B;
    --sl-color-accent-high: #E4C86B;
    --sl-color-text-accent: #D4A84B;
  }

  /* ── Remove content-panel padding (green space) ── */
  body:has(.pg-content) .content-panel {
    padding: 0 !important;
    margin: 0 !important;
  }

  /* ── Remove Starlight max-width constraints ── */
  body:has(.pg-content) .sl-container,
  body:has(.pg-content) .sl-markdown-content {
    max-width: 100% !important;
    padding-inline: 0 !important;
  }

  /* ── pg-content fills available height ── */
  .pg-content {
    height: calc(100vh - var(--sl-nav-height, 3.5rem) - 1.5rem);
    min-height: 500px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  @media (max-width: 1024px) {
    .pg-content {
      height: auto;
      min-height: calc(100vh - var(--sl-nav-height, 3.5rem));
      overflow-y: auto;
    }
  }

  /* ── astro-island must also stretch ── */
  .pg-content > astro-island,
  .pg-content > astro-island > div {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow: hidden;
    height: 100%;
  }

  @media (max-width: 1024px) {
    .pg-content > astro-island,
    .pg-content > astro-island > div {
      height: auto;
      min-height: 0;
      overflow: visible;
    }
  }
</style>
