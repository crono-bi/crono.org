<starlight-theme-toggle>
	<button aria-label="Cambiar tema" type="button">
		<svg class="icon sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<circle cx="12" cy="12" r="4"/>
			<path d="M12 2v2"/><path d="M12 20v2"/>
			<path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/>
			<path d="M2 12h2"/><path d="M20 12h2"/>
			<path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>
		</svg>
		<svg class="icon moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
		</svg>
	</button>
</starlight-theme-toggle>

{/* Sync icons immediately using Starlight's global theme provider */}
<script is:inline>
	(function() {
		var theme = document.documentElement.dataset.theme;
		document.querySelectorAll('starlight-theme-toggle').forEach(function(el) {
			var sun = el.querySelector('.sun');
			var moon = el.querySelector('.moon');
			if (sun) sun.style.display = theme === 'dark' ? 'block' : 'none';
			if (moon) moon.style.display = theme === 'dark' ? 'none' : 'block';
		});
	})();
</script>

<script>
	class StarlightThemeToggle extends HTMLElement {
		private btn: HTMLButtonElement;
		private sun: SVGElement;
		private moon: SVGElement;
		private observer: MutationObserver;

		constructor() {
			super();
			this.btn = this.querySelector('button')!;
			this.sun = this.querySelector('.sun')!;
			this.moon = this.querySelector('.moon')!;

			this.updateIcon();

			this.btn.addEventListener('click', () => {
				const html = document.documentElement;
				const current = html.dataset.theme;
				const next = current === 'dark' ? 'light' : 'dark';
				html.dataset.theme = next;
				localStorage.setItem('starlight-theme', next);
				this.updateIcon();
			});

			this.observer = new MutationObserver(() => this.updateIcon());
			this.observer.observe(document.documentElement, {
				attributes: true,
				attributeFilter: ['data-theme'],
			});
		}

		updateIcon() {
			const isDark = document.documentElement.dataset.theme === 'dark';
			this.sun.style.display = isDark ? 'block' : 'none';
			this.moon.style.display = isDark ? 'none' : 'block';
		}
	}

	customElements.define('starlight-theme-toggle', StarlightThemeToggle);
</script>

<style>
	starlight-theme-toggle {
		display: contents;
	}

	button {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 0.375rem;
		border: none;
		background: transparent;
		color: var(--sl-color-gray-1);
		cursor: pointer;
		transition: color 0.2s ease;
		padding: 0;
	}

	button:hover {
		color: var(--sl-color-accent);
	}

	.icon {
		display: none;
	}
</style>
