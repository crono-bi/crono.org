---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import PlaygroundSidebar from '../playground/components/PlaygroundSidebar.vue';

const isPlayground = Astro.url.pathname.startsWith('/playground');
---

<!-- CTA al Inicio -->
<div class="sidebar-cta-container">
	<a href="/" class="sidebar-home-cta">
		<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
			<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
			<polyline points="9 22 9 12 15 12 15 22"/>
		</svg>
		<span>Inicio</span>
	</a>
</div>

{isPlayground ? (
	<div class="sidebar-playground-container">
		<PlaygroundSidebar client:only="vue" />
	</div>
) : (
	<Default><slot /></Default>
)}

<style>
	.sidebar-cta-container {
		padding: 0.5rem 0;
		border-bottom: 1px solid var(--sl-color-gray-6);
	}

	.sidebar-home-cta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		font-size: var(--sl-text-base);
		color: var(--sl-color-gray-2);
		text-decoration: none;
		padding: 0.25rem var(--sl-sidebar-pad-x);
		border-radius: 6px;
		transition: background-color 0.2s, color 0.2s;
		margin: 0;
	}

	.sidebar-home-cta:hover {
		color: var(--sl-color-white);
		background: var(--sl-color-gray-6);
	}

	.sidebar-home-cta svg {
		flex-shrink: 0;
		opacity: 0.8;
		width: 16px;
		height: 16px;
	}
</style>
